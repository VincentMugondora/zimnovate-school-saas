---
export interface Props {
	userRole: 'admin' | 'teacher' | 'parent';
}

const { userRole } = Astro.props;
---

<header class="bg-white shadow-sm border-b border-gray-200">
	<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
		<div class="flex justify-between items-center h-16">
			<!-- Logo and School Name -->
			<div class="flex items-center">
				<div class="flex-shrink-0">
					<h1 class="text-xl font-bold text-blue-600">SchoolManager</h1>
				</div>
			</div>

			<!-- Navigation Links -->
			<nav class="hidden md:flex space-x-8">
				<a href="/dashboard" class="text-gray-700 hover:text-blue-600 px-3 py-2 text-sm font-medium transition-colors">
					Dashboard
				</a>
				{userRole === 'admin' && (
					<>
						<a href="/students" class="text-gray-700 hover:text-blue-600 px-3 py-2 text-sm font-medium transition-colors">
							Students
						</a>
						<a href="/users" class="text-gray-700 hover:text-blue-600 px-3 py-2 text-sm font-medium transition-colors">
							Users
						</a>
					</>
				)}
				<a href="/attendance" class="text-gray-700 hover:text-blue-600 px-3 py-2 text-sm font-medium transition-colors">
					Attendance
				</a>
				<a href="/grades" class="text-gray-700 hover:text-blue-600 px-3 py-2 text-sm font-medium transition-colors">
					Grades
				</a>
			</nav>

			<!-- Right side items -->
			<div class="flex items-center space-x-4">
				<!-- Sync Status Indicator -->
				<div class="flex items-center space-x-2">
					<div id="sync-status" class="w-2 h-2 bg-green-500 rounded-full" title="Synced"></div>
					<span class="text-xs text-gray-500 hidden sm:inline">Online</span>
				</div>

				<!-- Notifications -->
				<button class="text-gray-500 hover:text-gray-700 relative p-1">
					<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" />
					</svg>
					<span class="absolute top-0 right-0 block h-2 w-2 rounded-full bg-red-400"></span>
				</button>

				<!-- User Menu -->
				<div class="relative">
					<button class="flex items-center text-sm rounded-full focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500" id="user-menu">
						<div class="h-8 w-8 rounded-full bg-blue-500 flex items-center justify-center text-white font-medium">
							{userRole.charAt(0).toUpperCase()}
						</div>
					</button>
				</div>

				<!-- Logout -->
				<form action="/api/auth" method="POST" class="inline">
					<input type="hidden" name="action" value="logout">
					<button type="submit" class="text-gray-500 hover:text-gray-700 text-sm font-medium transition-colors">
						Logout
					</button>
				</form>
			</div>
		</div>
	</div>

	<!-- Mobile menu -->
	<div class="md:hidden border-t border-gray-200">
		<div class="px-2 pt-2 pb-3 space-y-1">
			<a href="/dashboard" class="block px-3 py-2 text-gray-700 hover:text-blue-600 hover:bg-gray-50 rounded-md text-base font-medium">
				Dashboard
			</a>
			{userRole === 'admin' && (
				<>
					<a href="/students" class="block px-3 py-2 text-gray-700 hover:text-blue-600 hover:bg-gray-50 rounded-md text-base font-medium">
						Students
					</a>
					<a href="/users" class="block px-3 py-2 text-gray-700 hover:text-blue-600 hover:bg-gray-50 rounded-md text-base font-medium">
						Users
					</a>
				</>
			)}
			<a href="/attendance" class="block px-3 py-2 text-gray-700 hover:text-blue-600 hover:bg-gray-50 rounded-md text-base font-medium">
				Attendance
			</a>
			<a href="/grades" class="block px-3 py-2 text-gray-700 hover:text-blue-600 hover:bg-gray-50 rounded-md text-base font-medium">
				Grades
			</a>
		</div>
	</div>
</header>

<script>
	// Mobile menu toggle
	const userMenu = document.getElementById('user-menu');
	if (userMenu) {
		userMenu.addEventListener('click', () => {
			// Toggle user dropdown (implementation needed)
			console.log('User menu clicked');
		});
	}
</script>
