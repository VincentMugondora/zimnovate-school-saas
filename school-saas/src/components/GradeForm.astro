---
export interface Props {
	classId: string;
	students: Array<{
		id: string;
		first_name: string;
		last_name: string;
		current_grade?: number;
	}>;
	gradingPeriod: string;
	assessmentName: string;
}

const { classId, students, gradingPeriod, assessmentName } = Astro.props;
---

<div class="bg-white rounded-lg shadow-md p-6">
	<div class="flex justify-between items-center mb-6">
		<div>
			<h3 class="text-lg font-semibold text-gray-900">
				{assessmentName} - {gradingPeriod}
			</h3>
			<p class="text-sm text-gray-500">
				{students.length} students in class
			</p>
		</div>
		<div class="flex items-center space-x-2">
			<div id="grade-sync-status" class="w-2 h-2 bg-green-500 rounded-full" title="All changes saved"></div>
			<span class="text-sm text-gray-500">Auto-save enabled</span>
		</div>
	</div>

	<form 
		id="grade-form"
		class="space-y-4"
	>
		<input type="hidden" name="class_id" value={classId} />
		<input type="hidden" name="grading_period" value={gradingPeriod} />
		<input type="hidden" name="assessment_name" value={assessmentName} />
		
		<div class="overflow-x-auto">
			<table class="min-w-full divide-y divide-gray-200">
				<thead class="bg-gray-50">
					<tr>
						<th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
							Student
						</th>
						<th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
							Grade (0-100)
						</th>
						<th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
							Status
						</th>
						<th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
							Notes
						</th>
					</tr>
				</thead>
				<tbody class="bg-white divide-y divide-gray-200">
					{students.map((student) => (
						<tr class="hover:bg-gray-50">
							<td class="px-6 py-4 whitespace-nowrap">
								<div class="flex items-center">
									<div class="h-8 w-8 rounded-full bg-blue-100 flex items-center justify-center mr-3">
										<span class="text-blue-600 font-semibold text-sm">
											{student.first_name.charAt(0)}{student.last_name.charAt(0)}
										</span>
									</div>
									<div>
										<div class="text-sm font-medium text-gray-900">
											{student.first_name} {student.last_name}
										</div>
										<div class="text-sm text-gray-500">
											ID: {student.id}
										</div>
									</div>
								</div>
							</td>
							<td class="px-6 py-4 whitespace-nowrap">
								<input 
									type="number" 
									name={`grade_${student.id}`}
									min="0" 
									max="100"
									value={student.current_grade || ''}
									placeholder="0-100"
									class="w-20 px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
									hx-post="/api/grades"
									hx-trigger="change delay:500ms"
									hx-include="this, input[name='class_id'], input[name='grading_period'], input[name='assessment_name']"
									hx-target="#grade-save-status"
									hx-swap="innerHTML"
								/>
							</td>
							<td class="px-6 py-4 whitespace-nowrap">
								<span 
									id={`status_${student.id}`}
									class="px-2 py-1 inline-flex text-xs leading-5 font-semibold rounded-full"
								>
									{student.current_grade ? (
										student.current_grade >= 70 ? (
											<span class="bg-green-100 text-green-800">Passing</span>
										) : (
											<span class="bg-red-100 text-red-800">Needs Improvement</span>
										)
									) : (
										<span class="bg-gray-100 text-gray-800">Not Graded</span>
									)}
								</span>
							</td>
							<td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
								<input 
									type="text" 
									name={`notes_${student.id}`}
									placeholder="Optional notes..."
									class="w-32 px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 text-sm"
								/>
							</td>
						</tr>
					))}
				</tbody>
			</table>
		</div>
		
		<div class="mt-6 flex justify-between items-center">
			<div id="grade-save-status" class="text-sm text-gray-500">
				Ready to save changes
			</div>
			
			<div class="flex space-x-3">
				<button 
					type="button"
					class="px-4 py-2 text-gray-700 bg-gray-100 hover:bg-gray-200 rounded-md transition-colors"
					onclick="resetGrades()"
				>
					Reset
				</button>
				<button 
					type="button"
					class="px-4 py-2 bg-blue-600 text-white hover:bg-blue-700 rounded-md transition-colors"
					onclick="saveAllGrades()"
				>
					Save All Grades
				</button>
			</div>
		</div>
	</form>
</div>

<script>
	function updateGradeStatus(studentId, grade) {
		const statusEl = document.getElementById(`status_${studentId}`);
		if (!statusEl) return;
		
		if (grade === '' || grade === null || grade === undefined) {
			statusEl.innerHTML = '<span class="bg-gray-100 text-gray-800">Not Graded</span>';
		} else if (grade >= 70) {
			statusEl.innerHTML = '<span class="bg-green-100 text-green-800">Passing</span>';
		} else {
			statusEl.innerHTML = '<span class="bg-red-100 text-red-800">Needs Improvement</span>';
		}
	}

	function saveGrade(studentId, grade, notes) {
		const classId = document.querySelector('input[name="class_id"]').value;
		const gradingPeriod = document.querySelector('input[name="grading_period"]').value;
		const assessmentName = document.querySelector('input[name="assessment_name"]').value;
		
		return fetch('/api/grades', {
			method: 'POST',
			headers: {
				'Content-Type': 'application/json',
			},
			body: JSON.stringify({
				student_id: studentId,
				class_id: classId,
				grade: parseFloat(grade),
				grading_period: gradingPeriod
			})
		})
		.then(response => response.json())
		.then(data => {
			const statusEl = document.getElementById('grade-save-status');
			if (data.error) {
				statusEl.textContent = 'Error: ' + data.error;
				statusEl.className = 'text-sm text-red-600';
			} else {
				statusEl.textContent = `Saved: ${student.first_name} ${student.last_name}`;
				statusEl.className = 'text-sm text-green-600';
				
				// Update sync status
				const syncIndicator = document.getElementById('grade-sync-status');
				syncIndicator.className = 'w-2 h-2 bg-green-500 rounded-full';
				
				// Update status badge
				updateGradeStatus(studentId, grade);
				
				setTimeout(() => {
					statusEl.textContent = 'All changes saved';
					statusEl.className = 'text-sm text-gray-500';
				}, 3000);
			}
		})
		.catch(error => {
			console.error('Error:', error);
			const statusEl = document.getElementById('grade-save-status');
			statusEl.textContent = 'Error saving grade';
			statusEl.className = 'text-sm text-red-600';
		});
	}

	// Handle grade input changes
	document.addEventListener('change', function(e) {
		if (e.target.type === 'number' && e.target.name.startsWith('grade_')) {
			const studentId = e.target.name.replace('grade_', '');
			const grade = e.target.value;
			const notesInput = document.querySelector(`input[name="notes_${studentId}"]`);
			const notes = notesInput ? notesInput.value : '';
			
			if (grade !== '') {
				saveGrade(studentId, grade, notes);
			}
			
			updateGradeStatus(studentId, grade);
		}
	});

	function resetGrades() {
		if (confirm('Are you sure you want to reset all grades? This action cannot be undone.')) {
			document.querySelectorAll('input[name^="grade_"]').forEach(input => {
				input.value = '';
				const studentId = input.name.replace('grade_', '');
				updateGradeStatus(studentId, '');
			});
		}
	}

	function saveAllGrades() {
		const gradeInputs = document.querySelectorAll('input[name^="grade_"]');
		let savePromises = [];
		
		gradeInputs.forEach(input => {
			const studentId = input.name.replace('grade_', '');
			const grade = input.value;
			const notesInput = document.querySelector(`input[name="notes_${studentId}"]`);
			const notes = notesInput ? notesInput.value : '';
			
			if (grade !== '') {
				savePromises.push(saveGrade(studentId, grade, notes));
			}
		});
		
		Promise.all(savePromises).then(() => {
			const statusEl = document.getElementById('grade-save-status');
			statusEl.textContent = 'All grades saved successfully';
			statusEl.className = 'text-sm text-green-600';
		});
	}
</script>
