---
export interface Props {
	events: Array<{
		id: string;
		title: string;
		date: string;
		time: string;
		location?: string;
		type: 'holiday' | 'exam' | 'meeting' | 'event' | 'sports';
		attendees?: number;
	}>;
}

const { 
	events = [
		{ id: '1', title: 'Parent-Teacher Meeting', date: '2024-02-15', time: '4:00 PM', location: 'Main Hall', type: 'meeting', attendees: 120 },
		{ id: '2', title: 'Science Fair', date: '2024-02-18', time: '9:00 AM', type: 'event', attendees: 250 },
		{ id: '3', title: 'Mid-Term Exams Begin', date: '2024-02-20', time: '8:00 AM', type: 'exam' },
		{ id: '4', title: 'Sports Day', date: '2024-02-25', time: '8:00 AM', location: 'Stadium', type: 'sports', attendees: 500 },
		{ id: '5', title: 'Winter Break starts', date: '2024-03-01', time: '3:00 PM', type: 'holiday' },
	]
} = Astro.props;

const typeStyles = {
	holiday: { bg: 'bg-red-100', text: 'text-red-700', icon: 'sun' },
	exam: { bg: 'bg-purple-100', text: 'text-purple-700', icon: 'clipboard' },
	meeting: { bg: 'bg-blue-100', text: 'text-blue-700', icon: 'users' },
	event: { bg: 'bg-teal-100', text: 'text-teal-700', icon: 'calendar' },
	sports: { bg: 'bg-orange-100', text: 'text-orange-700', icon: 'trophy' },
};

const typeIcons = {
	sun: `<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><circle cx="12" cy="12" r="5"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 1v2m0 18v2M4.22 4.22l1.42 1.42m12.72 12.72l1.42 1.42M1 12h2m18 0h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg>`,
	clipboard: `<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>`,
	users: `<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg>`,
	calendar: `<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>`,
	trophy: `<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M6 9H4.5a2.5 2.5 0 010-5H6"/><path d="M18 9h1.5a2.5 2.5 0 010 5H18"/><path d="M4 22h16"/><path d="M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20.24 7 22"/><path d="M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20.24 17 22"/><path d="M18 2H6v7a6 6 0 0012 0V2z"/></svg>`,
};

const formatDate = (dateStr: string) => {
	const date = new Date(dateStr);
	return date.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
};

const isUpcoming = (dateStr: string) => {
	const date = new Date(dateStr);
	const today = new Date();
	return date >= today;
};
---

<div class="bg-white rounded-3xl shadow-card p-6 md:p-8 border border-gray-100 h-full">
	<div class="flex items-center justify-between mb-6">
		<div>
			<h3 class="text-lg font-heading font-semibold text-gray-900">Upcoming Events</h3>
			<p class="text-sm text-gray-500 mt-1">What's happening next</p>
		</div>
		<button class="px-4 py-2 text-sm font-medium text-teal-600 bg-teal-50 hover:bg-teal-100 rounded-xl transition-colors">
			Calendar
		</button>
	</div>
	
	<div class="space-y-3">
		{events.filter(isUpcoming).slice(0, 5).map((event) => {
			const style = typeStyles[event.type] || typeStyles.event;
			
			return (
				<a href={`/events/${event.id}`} class="group flex items-center gap-4 p-3 rounded-2xl hover:bg-beige-50 transition-all border border-transparent hover:border-gray-100">
					<!-- Date Circle -->
					<div class="w-14 h-14 rounded-2xl bg-beige-100 flex flex-col items-center justify-center flex-shrink-0 group-hover:bg-teal-50 transition-colors">
						<span class="text-xs font-semibold text-gray-500 uppercase">
							{new Date(event.date).toLocaleDateString('en-US', { month: 'short' })}
						</span>
						<span class="text-lg font-bold text-gray-900 leading-none">
							{new Date(event.date).getDate()}
						</span>
					</div>
					
					<!-- Event Details -->
					<div class="flex-1 min-w-0">
						<h4 class="text-sm font-semibold text-gray-900 group-hover:text-teal-600 transition-colors line-clamp-1">
							{event.title}
						</h4>
						<div class="flex items-center gap-3 mt-1 text-xs text-gray-500">
							<span class="flex items-center">
								<svg class="w-3.5 h-3.5 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
								</svg>
								{event.time}
							</span>
							{event.location && (
								<span class="flex items-center">
									<svg class="w-3.5 h-3.5 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
									</svg>
									{event.location}
								</span>
							)}
						</div>
					</div>
					
					<!-- Type Badge -->
					<div className={`w-8 h-8 rounded-xl ${style.bg} flex items-center justify-center flex-shrink-0`}>
						<div class={style.text}>
							{typeIcons[style.icon as keyof typeof typeIcons]}
						</div>
					</div>
				</a>
			);
		})}
	</div>
	
	{events.filter(isUpcoming).length === 0 && (
		<div class="text-center py-8">
			<div class="w-16 h-16 mx-auto mb-3 rounded-2xl bg-beige-100 flex items-center justify-center">
				<svg class="w-8 h-8 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
				</svg>
			</div>
			<p class="text-sm text-gray-500">No upcoming events</p>
		</div>
	)}
</div>
