---
export interface Props {
	teachers: Array<{
		id: string;
		name: string;
		subject: string;
		avatar?: string;
		performance: number;
		classesTaught: number;
		students: number;
		rating: number;
	}>;
}

const { 
	teachers = [
		{ id: '1', name: 'Sarah Johnson', subject: 'Mathematics', performance: 95, classesTaught: 4, students: 96, rating: 4.9 },
		{ id: '2', name: 'Michael Chen', subject: 'Physics', performance: 92, classesTaught: 3, students: 72, rating: 4.8 },
		{ id: '3', name: 'Emily Davis', subject: 'English', performance: 89, classesTaught: 5, students: 120, rating: 4.7 },
		{ id: '4', name: 'James Wilson', subject: 'History', performance: 94, classesTaught: 3, students: 68, rating: 4.9 },
		{ id: '5', name: 'Lisa Garcia', subject: 'Biology', performance: 91, classesTaught: 3, students: 75, rating: 4.6 },
	]
} = Astro.props;

const getPerformanceColor = (score: number) => {
	if (score >= 90) return 'bg-green-500';
	if (score >= 80) return 'bg-teal-500';
	if (score >= 70) return 'bg-yellow-500';
	return 'bg-red-500';
};
---

<div class="bg-white rounded-3xl shadow-card p-6 md:p-8 border border-gray-100">
	<div class="flex items-center justify-between mb-6">
		<div>
			<h3 class="text-lg font-heading font-semibold text-gray-900">Teacher Performance</h3>
			<p class="text-sm text-gray-500 mt-1">Based on student feedback & results</p>
		</div>
		<button class="px-4 py-2 text-sm font-medium text-teal-600 bg-teal-50 hover:bg-teal-100 rounded-xl transition-colors">
			View All
		</button>
	</div>
	
	<div class="space-y-5">
		{teachers.sort((a, b) => b.performance - a.performance).slice(0, 5).map((teacher, index) => (
			<div class="group flex items-center gap-4 p-4 rounded-2xl hover:bg-beige-50 transition-colors border border-transparent hover:border-gray-100">
				<!-- Rank -->
				<div class="w-8 h-8 rounded-xl bg-beige-100 flex items-center justify-center">
					<span class="text-sm font-bold text-gray-700">#{index + 1}</span>
				</div>
				
				<!-- Avatar -->
				<div class="w-12 h-12 rounded-full bg-gradient-to-br from-teal-400 to-cyan-500 flex items-center justify-center text-white font-semibold shadow-sm">
					{teacher.name.split(' ').map(n => n[0]).join('').substring(0, 2)}
				</div>
				
				<!-- Info -->
				<div class="flex-1 min-w-0">
					<div class="flex items-center gap-2">
						<h4 class="text-sm font-semibold text-gray-900 truncate">{teacher.name}</h4>
						<div class="flex items-center text-xs text-yellow-500">
							<svg class="w-3.5 h-3.5 fill-current" viewBox="0 0 20 20">
								<path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
							</svg>
							<span class="text-gray-700 font-medium">{teacher.rating}</span>
						</div>
					</div>
					<p class="text-xs text-gray-500">{teacher.subject} • {teacher.classesTaught} classes • {teacher.students} students</p>
				</div>
				
				<!-- Performance Score -->
				<div class="text-right">
					<p class="text-lg font-heading font-bold text-teal-600">{teacher.performance}%</p>
					<div class="w-20 h-2 bg-gray-100 rounded-full mt-1 overflow-hidden">
						<div 
							class={`h-full ${getPerformanceColor(teacher.performance)} rounded-full transition-all duration-700`}
							style={`width: ${teacher.performance}%`}
						></div>
					</div>
				</div>
			</div>
		))}
	</div>
</div>
