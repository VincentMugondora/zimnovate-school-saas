---
export interface Props {
	announcements: Array<{
		id: string;
		title: string;
		excerpt: string;
		author: string;
		date: string;
		type: 'general' | 'urgent' | 'event' | 'academic';
		priority: 'high' | 'medium' | 'low';
	}>;
	maxItems?: number;
}

const { announcements = [], maxItems = 5 } = Astro.props;

const typeStyles = {
	general: { bg: 'bg-blue-100', text: 'text-blue-700', icon: 'info' },
	urgent: { bg: 'bg-red-100', text: 'text-red-700', icon: 'alert' },
	event: { bg: 'bg-purple-100', text: 'text-purple-700', icon: 'calendar' },
	academic: { bg: 'bg-green-100', text: 'text-green-700', icon: 'book' },
};

const typeIcons = {
	info: `<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`,
	alert: `<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`,
	calendar: `<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>`,
	book: `<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>`,
};
---

<div class="bg-white rounded-3xl shadow-card p-6 md:p-8 border border-gray-100 h-full">
	<div class="flex items-center justify-between mb-6">
		<div>
			<h3 class="text-lg font-heading font-semibold text-gray-900">Recent Announcements</h3>
			<p class="text-sm text-gray-500 mt-1">Latest updates from administration</p>
		</div>
		<button class="p-2 hover:bg-beige-100 rounded-xl transition-colors">
			<svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
				<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
			</svg>
		</button>
	</div>
	
	<div class="space-y-4">
		{announcements.length > 0 ? (
			announcements.slice(0, maxItems).map((announcement) => {
				const style = typeStyles[announcement.type] || typeStyles.general;
				
				return (
					<a href={`/announcements/${announcement.id}`} class="group block p-4 rounded-2xl border border-gray-100 hover:border-teal-200 hover:shadow-soft transition-all duration-200">
						<div class="flex items-start gap-3">
							<div class={`w-10 h-10 rounded-xl ${style.bg} flex items-center justify-center flex-shrink-0`}>
								<div class={style.text}>
									{typeIcons[style.icon as keyof typeof typeIcons]}
								</div>
							</div>
							
							<div class="flex-1 min-w-0">
								<div class="flex items-center gap-2 mb-1">
									<span class={`inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium ${style.bg} ${style.text}`}>
										{typeIcons[style.icon as keyof typeof typeIcons]}
										<span class="ml-1 capitalize">{announcement.type}</span>
									</span>
									{announcement.priority === 'high' && (
										<span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-700">
											Urgent
										</span>
									)}
								</div>
								
								<h4 class="text-sm font-semibold text-gray-900 group-hover:text-teal-600 transition-colors line-clamp-1">
									{announcement.title}
								</h4>
								<p class="text-xs text-gray-500 mt-1 line-clamp-2">
									{announcement.excerpt}
								</p>
								
								<div class="flex items-center gap-3 mt-2 text-xs text-gray-400">
									<span class="flex items-center">
										<svg class="w-3.5 h-3.5 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
											<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
										</svg>
										{announcement.author}
									</span>
									<span class="flex items-center">
										<svg class="w-3.5 h-3.5 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
											<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
										</svg>
										{announcement.date}
									</span>
								</div>
							</div>
						</div>
					</a>
				);
			})
		) : (
			<div class="text-center py-8">
				<div class="w-16 h-16 mx-auto mb-3 rounded-2xl bg-beige-100 flex items-center justify-center">
					<svg class="w-8 h-8 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
					</svg>
				</div>
				<p class="text-sm text-gray-500">No announcements yet</p>
			</div>
		)}
	</div>
</div>
