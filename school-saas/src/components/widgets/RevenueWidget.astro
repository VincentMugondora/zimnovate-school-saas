---
export interface Props {
	totalRevenue: number;
	monthlyGrowth: number;
	currency?: string;
	recentTransactions: Array<{
		id: string;
		description: string;
		amount: number;
		status: 'completed' | 'pending' | 'failed';
		date: string;
	}>;
}

const { totalRevenue, monthlyGrowth, currency = '$', recentTransactions } = Astro.props;
---

<!-- Revenue Overview Card -->
<div class="bg-gradient-to-br from-teal-500 to-teal-600 rounded-3xl p-6 md:p-8 text-white shadow-lg relative overflow-hidden">
	<!-- Background decoration -->
	<div class="absolute top-0 right-0 w-32 h-32 bg-white/10 rounded-full blur-2xl -translate-y-1/2 translate-x-1/2"></div>
	<div class="absolute bottom-0 left-0 w-24 h-24 bg-black/10 rounded-full blur-xl translate-y-1/2 -translate-x-1/2"></div>
	
	<div class="relative">
		<div class="flex items-start justify-between mb-6">
			<div>
				<p class="text-teal-100 text-sm font-medium mb-1">Total Revenue</p>
				<h3 class="text-3xl md:text-4xl font-heading font-bold">
					{currency}{totalRevenue.toLocaleString()}
				</h3>
			</div>
			<div class="p-3 bg-white/20 rounded-2xl backdrop-blur-sm">
				<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
				</svg>
			</div>
		</div>
		
		<!-- Growth Indicator -->
		<div class="flex items-center space-x-2 mb-6">
			<div class={`flex items-center px-2.5 py-1 rounded-full text-xs font-medium ${monthlyGrowth >= 0 ? 'bg-green-500/20 text-green-100' : 'bg-red-500/20 text-red-100'}`}>
				<svg class={`w-3 h-3 mr-1 ${monthlyGrowth >= 0 ? '' : 'rotate-180'}`} fill="currentColor" viewBox="0 0 20 20">
					<path fill-rule="evenodd" d="M5.293 9.707a1 1 0 010-1.414l4-4a1 1 0 011.414 0l4 4a1 1 0 01-1.414 1.414L11 7.414V15a1 1 0 11-2 0V7.414L6.707 9.707a1 1 0 01-1.414 0z" clip-rule="evenodd"/>
				</svg>
				{monthlyGrowth >= 0 ? '+' : ''}{monthlyGrowth}%
			</div>
			<span class="text-teal-100 text-sm">vs last month</span>
		</div>
		
		<!-- Mini Chart Preview -->
		<div class="flex items-end space-x-1 h-12">
			{[45, 60, 55, 70, 65, 80, 75, 90, 85, 95, 88, 100].map((height, i) => (
				<div 
					class="flex-1 bg-white/20 rounded-t-sm transition-all duration-700 hover:bg-white/30"
					style={`height: ${height}%`}
				></div>
			))}
		</div>
	</div>
</div>

<!-- Recent Transactions -->
<div class="mt-6 space-y-4">
	<h4 class="text-sm font-semibold text-gray-700 mb-3">Recent Transactions</h4>
	{recentTransactions.slice(0, 4).map((tx) => (
		<div class="flex items-center justify-between p-3 bg-white rounded-2xl hover:shadow-soft transition-shadow border border-gray-100">
			<div class="flex items-center space-x-3">
				<div class={`w-10 h-10 rounded-xl flex items-center justify-center ${
					tx.status === 'completed' ? 'bg-green-100 text-green-600' :
					tx.status === 'pending' ? 'bg-yellow-100 text-yellow-600' :
					'bg-red-100 text-red-600'
				}`}>
					{tx.status === 'completed' ? (
						<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
						</svg>
					) : tx.status === 'pending' ? (
						<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
						</svg>
					) : (
						<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
						</svg>
					)}
				</div>
				<div>
					<p class="text-sm font-medium text-gray-900">{tx.description}</p>
					<p class="text-xs text-gray-500">{tx.date}</p>
				</div>
			</div>
			<span class={`font-semibold text-sm ${tx.status === 'completed' ? 'text-green-600' : tx.status === 'pending' ? 'text-yellow-600' : 'text-red-600'}`}>
				{currency}{tx.amount.toLocaleString()}
			</span>
		</div>
	))}
</div>
