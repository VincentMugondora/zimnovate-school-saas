---
export interface Props {
	value: number | string;
	label: string;
	icon?: any;
	trend?: {
		value: number;
		isPositive: boolean;
	};
	variant?: 'teal' | 'cyan' | 'orange' | 'blue';
	class?: string;
}

const { value, label, icon, trend, variant = 'teal', className } = Astro.props;

const variantStyles = {
	teal: {
		bg: 'bg-teal-50',
		iconBg: 'bg-teal-500',
		text: 'text-teal-600',
		border: 'border-teal-100',
	},
	cyan: {
		bg: 'bg-cyan-50',
		iconBg: 'bg-cyan-500',
		text: 'text-cyan-600',
		border: 'border-cyan-100',
	},
	orange: {
		bg: 'bg-orange-50',
		iconBg: 'bg-orange-500',
		text: 'text-orange-600',
		border: 'border-orange-100',
	},
	blue: {
		bg: 'bg-blue-50',
		iconBg: 'bg-blue-500',
		text: 'text-blue-600',
		border: 'border-blue-100',
	},
};

const styles = variantStyles[variant];
---

<div class={`bg-white rounded-3xl shadow-card p-6 transition-all duration-300 hover:shadow-soft hover:-translate-y-1 border border-gray-100 ${className || ''}`}>
	<div class="flex items-start justify-between">
		<div class="flex-1">
			<p class="text-sm font-medium text-gray-500 mb-2">{label}</p>
			<p class="text-3xl font-heading font-bold text-gray-900">{value}</p>
			
			{trend && (
				<div class="flex items-center mt-3">
					<span class={`text-sm font-medium ${trend.isPositive ? 'text-green-600' : 'text-red-600'}`}>
						{trend.isPositive ? '+' : ''}{trend.value}%
					</span>
					<span class="text-xs text-gray-400 ml-2">vs last month</span>
				</div>
			)}
		</div>
		
		{icon && (
			<div class={`${styles.bg} p-4 rounded-2xl`}>
				{icon}
			</div>
		)}
	</div>
</div>
