---
export interface Props {
	children: any;
	class?: string;
	title?: string;
	 subtitle?: string;
}

const { class: className, title, subtitle, children } = Astro.props;
---

<div class={`bg-white rounded-3xl shadow-soft p-6 md:p-8 transition-all duration-300 hover:shadow-elevated ${className || ''}`}>
	{(title || subtitle) && (
		<div class="mb-6">
			{title && <h3 class="text-xl font-heading font-semibold text-gray-900">{title}</h3>}
			{subtitle && <p class="text-sm text-gray-500 mt-1">{subtitle}</p>}
		</div>
	)}
	<div class={title || subtitle ? '' : 'h-full'}>
		{children}
	</div>
</div>
