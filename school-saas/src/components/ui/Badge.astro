---
export interface Props {
	variant?: 'teal' | 'cyan' | 'orange' | 'green' | 'red' | 'yellow' | 'gray';
	size?: 'sm' | 'md';
	children: any;
	class?: string;
}

const { variant = 'teal', size = 'md', children, className } = Astro.props;

const variantStyles = {
	teal: 'bg-teal-100 text-teal-700 border-teal-200',
	cyan: 'bg-cyan-100 text-cyan-700 border-cyan-200',
	orange: 'bg-orange-100 text-orange-700 border-orange-200',
	green: 'bg-green-100 text-green-700 border-green-200',
	red: 'bg-red-100 text-red-700 border-red-200',
	yellow: 'bg-yellow-100 text-yellow-700 border-yellow-200',
	gray: 'bg-gray-100 text-gray-700 border-gray-200',
};

const sizeStyles = {
	sm: 'px-2.5 py-0.5 text-xs',
	md: 'px-3 py-1 text-sm',
};

const styles = `${variantStyles[variant]} ${sizeStyles[size]} border rounded-full font-medium transition-all duration-200 hover:opacity-80`;
---

<span class={`inline-flex items-center ${styles} ${className || ''}`}>
	{children}
</span>
