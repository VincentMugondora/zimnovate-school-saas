---
export interface Props {
	variant?: 'primary' | 'secondary' | 'ghost';
	size?: 'sm' | 'md' | 'lg';
	children: any;
	href?: string;
	class?: string;
	onclick?: any;
	type?: 'button' | 'submit' | 'reset';
}

const { variant = 'primary', size = 'md', children, href, className, onclick, type = 'button' } = Astro.props;

const variantStyles = {
	primary: 'bg-teal-500 text-white hover:bg-teal-600 shadow-soft',
	secondary: 'bg-white text-gray-700 border border-gray-200 hover:bg-gray-50',
	ghost: 'bg-transparent text-gray-600 hover:bg-gray-100',
};

const sizeStyles = {
	sm: 'px-3 py-1.5 text-sm rounded-xl',
	md: 'px-4 py-2 text-sm rounded-xl',
	lg: 'px-6 py-3 text-base rounded-xl',
};

const styles = `${variantStyles[variant]} ${sizeStyles[size]} font-medium transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-teal-500 focus:ring-offset-2`;
---

{
	href ? (
		<a href={href} class={`inline-flex items-center justify-center font-medium ${styles} ${className || ''}`}>
			{children}
		</a>
	) : (
		<button type={type} onclick={onclick} class={`inline-flex items-center justify-center font-medium ${styles} ${className || ''}`}>
			{children}
		</button>
	)
}
