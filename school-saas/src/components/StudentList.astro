---
export interface Props {
	students: Array<{
		id: string;
		first_name: string;
		last_name: string;
		email?: string;
		grade_level: number;
		enrollment_date: string;
	}>;
	showActions?: boolean;
	editable?: boolean;
}

const { students, showActions = true, editable = false } = Astro.props;
---

<div class="bg-white rounded-lg shadow-md overflow-hidden">
	<div class="px-6 py-4 border-b border-gray-200">
		<div class="flex justify-between items-center">
			<h3 class="text-lg font-semibold text-gray-900">
				Students ({students.length})
			</h3>
			{editable && (
				<button 
					class="px-4 py-2 bg-blue-600 text-white hover:bg-blue-700 rounded-md transition-colors text-sm"
					hx-get="/students/create"
					hx-target="#modal-content"
					hx-trigger="click"
				>
					Add Student
				</button>
			)}
		</div>
	</div>

	<div class="overflow-x-auto">
		<table class="min-w-full divide-y divide-gray-200">
			<thead class="bg-gray-50">
				<tr>
					<th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
						Name
					</th>
					<th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
						Grade
					</th>
					<th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
						Email
					</th>
					<th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
						Enrolled
					</th>
					{showActions && (
						<th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
							Actions
						</th>
					)}
				</tr>
			</thead>
			<tbody class="bg-white divide-y divide-gray-200">
				{students.length === 0 ? (
					<tr>
						<td colSpan={showActions ? "5" : "4"} class="px-6 py-12 text-center text-gray-500">
							<div class="flex flex-col items-center">
								<svg class="w-12 h-12 text-gray-400 mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" />
								</svg>
								<p class="text-lg font-medium">No students found</p>
								<p class="text-sm">Get started by adding your first student</p>
								{editable && (
									<button 
										class="mt-4 px-4 py-2 bg-blue-600 text-white hover:bg-blue-700 rounded-md transition-colors text-sm"
										hx-get="/students/create"
										hx-target="#modal-content"
										hx-trigger="click"
									>
										Add First Student
									</button>
								)}
							</div>
						</td>
					</tr>
				) : (
					students.map((student) => (
						<tr class="hover:bg-gray-50" id={`student-row-${student.id}`}>
							<td class="px-6 py-4 whitespace-nowrap">
								<div class="flex items-center">
									<div class="h-10 w-10 rounded-full bg-blue-100 flex items-center justify-center mr-3">
										<span class="text-blue-600 font-semibold">
											{student.first_name.charAt(0)}{student.last_name.charAt(0)}
										</span>
									</div>
									<div>
										<div class="text-sm font-medium text-gray-900">
											{student.first_name} {student.last_name}
										</div>
										<div class="text-sm text-gray-500">
											ID: {student.id}
										</div>
									</div>
								</div>
							</td>
							<td class="px-6 py-4 whitespace-nowrap">
								<span class="px-2 py-1 inline-flex text-xs leading-5 font-semibold rounded-full bg-blue-100 text-blue-800">
									Grade {student.grade_level}
								</span>
							</td>
							<td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
								{student.email || (
									<span class="text-gray-400 italic">No email</span>
								)}
							</td>
							<td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
								{new Date(student.enrollment_date).toLocaleDateString()}
							</td>
							{showActions && (
								<td class="px-6 py-4 whitespace-nowrap text-sm font-medium">
									<div class="flex space-x-2">
										<a 
											href={`/students/${student.id}`}
											class="text-blue-600 hover:text-blue-900 transition-colors"
										>
											View
										</a>
										{editable && (
											<>
												<button 
													class="text-indigo-600 hover:text-indigo-900 transition-colors"
													hx-get={`/students/${student.id}/edit`}
													hx-target="#modal-content"
													hx-trigger="click"
												>
													Edit
												</button>
												<button 
													class="text-red-600 hover:text-red-900 transition-colors"
													hx-delete={`/api/students/${student.id}`}
													hx-target={`#student-row-${student.id}`}
													hx-trigger="click"
													hx-confirm="Are you sure you want to delete this student?"
												>
													Delete
												</button>
											</>
										)}
									</div>
								</td>
							)}
						</tr>
					))
				)}
			</tbody>
		</table>
	</div>

	{students.length > 0 && (
		<div class="px-6 py-4 border-t border-gray-200 bg-gray-50">
			<div class="flex justify-between items-center">
				<p class="text-sm text-gray-700">
					Showing <span class="font-medium">{students.length}</span> students
				</p>
				{editable && (
					<div class="flex space-x-2">
						<button 
							class="px-3 py-1 text-sm text-gray-700 bg-white border border-gray-300 rounded-md hover:bg-gray-50 transition-colors"
							hx-get="/api/students/export"
							hx-target="#export-status"
						>
							Export CSV
						</button>
						<button 
							class="px-3 py-1 text-sm text-gray-700 bg-white border border-gray-300 rounded-md hover:bg-gray-50 transition-colors"
							hx-get="/students/import"
							hx-target="#modal-content"
							hx-trigger="click"
						>
							Import CSV
						</button>
					</div>
				)}
			</div>
		</div>
	)}
</div>

<div id="export-status" class="hidden"></div>
