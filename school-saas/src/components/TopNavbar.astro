---
export interface Props {
	userName: string;
	userRole: string;
	notificationCount?: number;
}

const { userName, userRole, notificationCount = 3 } = Astro.props;

const initials = userName.split(' ').map(n => n[0]).join('').substring(0, 2).toUpperCase();
---

<header class="h-16 bg-white/80 backdrop-blur-glass border-b border-gray-200 sticky top-0 z-50">
	<div class="h-full px-4 md:px-6 flex items-center justify-between">
		<!-- Left: Page Title / Mobile Menu Toggle -->
		<div class="flex items-center space-x-4">
			<button class="lg:hidden p-2 rounded-xl hover:bg-beige-100 transition-colors" onclick="toggleSidebar()">
				<svg class="w-6 h-6 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
				</svg>
			</button>
			<h2 class="text-lg font-heading font-semibold text-gray-900 hidden sm:block">
				<slot name="title" />
			</h2>
		</div>

		<!-- Center: Search Bar -->
		<div class="hidden md:flex flex-1 max-w-lg mx-6">
			<div class="relative w-full group">
				<svg class="absolute left-3 top-1/2 -translate-y-1/2 w-5 h-5 text-gray-400 group-focus-within:text-teal-500 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
				</svg>
				<input 
					type="text" 
					placeholder="Search students, classes, teachers..." 
					class="w-full pl-10 pr-4 py-2.5 bg-beige-100/50 border border-transparent focus:border-teal-200 rounded-2xl text-sm text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-teal-500/20 focus:bg-white transition-all duration-200"
				/>
			</div>
		</div>

		<!-- Right: Actions -->
		<div class="flex items-center space-x-2 md:space-x-4">
			<!-- Mobile Search Toggle -->
			<button class="md:hidden p-2 rounded-xl hover:bg-beige-100 transition-colors">
				<svg class="w-5 h-5 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
				</svg>
			</button>

			<!-- Sync Status -->
			<div class="hidden sm:flex items-center space-x-2 px-3 py-1.5 rounded-full bg-green-50 border border-green-100">
				<div class="w-2 h-2 bg-green-500 rounded-full animate-pulse"></div>
				<span class="text-xs font-medium text-green-700">Synced</span>
			</div>

			<!-- Notifications -->
			<button class="relative p-2.5 rounded-xl hover:bg-beige-100 transition-colors group">
				<svg class="w-5 h-5 text-gray-600 group-hover:text-gray-900" fill="none" stroke="currentColor" viewBox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/>
				</svg>
				{notificationCount > 0 && (
					<span class="absolute top-1 right-1 w-4 h-4 bg-orange-500 text-white text-xs font-bold rounded-full flex items-center justify-center">
						{notificationCount > 9 ? '9+' : notificationCount}
					</span>
				)}
			</button>

			<!-- User Avatar -->
			<div class="relative">
				<button class="flex items-center space-x-2 p-1.5 rounded-xl hover:bg-beige-100 transition-colors" id="user-menu-button">
					<div class="w-9 h-9 rounded-full bg-gradient-to-br from-teal-400 to-teal-600 flex items-center justify-center text-white font-semibold text-sm shadow-sm">
						{initials}
					</div>
					<svg class="w-4 h-4 text-gray-400 hidden sm:block" fill="none" stroke="currentColor" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
					</svg>
				</button>
			</div>
		</div>
	</div>
</header>

<script>
	function toggleSidebar() {
		const sidebar = document.querySelector('aside');
		if (sidebar) {
			sidebar.classList.toggle('hidden');
			sidebar.classList.toggle('absolute');
			sidebar.classList.toggle('z-50');
			sidebar.classList.toggle('h-full');
		}
	}
</script>
