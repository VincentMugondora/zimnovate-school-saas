---
export interface Props {
	data: Array<{ label: string; value: number }>;
	height?: number;
	color?: string;
	strokeWidth?: number;
	showDots?: boolean;
	showArea?: boolean;
	class?: string;
}

const { 
	data, 
	height = 200, 
	color = '#00A8B5', 
	strokeWidth = 3,
	showDots = true,
	showArea = true,
	className 
} = Astro.props;

const maxValue = Math.max(...data.map(d => d.value)) || 1;
const points = data.map((d, i) => {
	const x = (i / (data.length - 1 || 1)) * 100;
	const y = 100 - ((d.value / maxValue) * 100);
	return `${x},${y}`;
}).join(' ');

const areaPoints = `0,100 ${points} 100,100`;
---

<div class={`w-full ${className || ''}`}>
	<svg viewBox="0 0 100 100" preserveAspectRatio="none" class={`w-full`} style={`height: ${height}px`}>
		<!-- Gradient definition -->
		<defs>
			<linearGradient id={`gradient-${color.replace('#', '')}`} x1="0%" y1="0%" x2="0%" y2="100%">
				<stop offset="0%" stopColor={color} stopOpacity="0.2"/>
				<stop offset="100%" stopColor={color} stopOpacity="0"/>
			</linearGradient>
			<filter id="shadow" x="-20%" y="-20%" width="140%" height="140%">
				<feDropShadow dx="0" dy="2" stdDeviation="1.5" floodColor={color} floodOpacity="0.3"/>
			</filter>
		</defs>
		
		<!-- Grid lines -->
		<line x1="0" y1="25" x2="100" y2="25" stroke="#e5e7eb" stroke-width="0.2" stroke-dasharray="2,2" />
		<line x1="0" y1="50" x2="100" y2="50" stroke="#e5e7eb" stroke-width="0.2" stroke-dasharray="2,2" />
		<line x1="0" y1="75" x2="100" y2="75" stroke="#e5e7eb" stroke-width="0.2" stroke-dasharray="2,2" />
		
		<!-- Area fill -->
		{showArea && (
			<polygon 
				points={areaPoints}
				fill={`url(#gradient-${color.replace('#', '')})`}
				class="animate-fade-in"
			/>
		)}
		
		<!-- Line -->
		<polyline 
			points={points}
			fill="none"
			stroke={color}
			stroke-width={strokeWidth}
			stroke-linecap="round"
			stroke-linejoin="round"
			filter="url(#shadow)"
			class="animate-fade-in"
		/>
		
		<!-- Data points -->
		{showDots && data.map((d, i) => {
			const x = (i / (data.length - 1 || 1)) * 100;
			const y = 100 - ((d.value / maxValue) * 100);
			return (
				<circle 
					cx={x} 
					cy={y} 
					r="1.2" 
					fill="white" 
					stroke={color}
					stroke-width="0.6"
					class="hover:r-2 transition-all duration-200"
				/>
			);
		})}
	</svg>
	
	<!-- X-axis labels -->
	<div class="flex justify-between mt-3">
		{data.map((d, i) => (
			<span class="text-xs text-gray-400 truncate" style={{ width: `${100 / data.length}%` }}>
				{d.label}
			</span>
		))}
	</div>
</div>
