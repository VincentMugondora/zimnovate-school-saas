---
export interface Props {
	data: Array<{ label: string; value: number; color?: string }>;
	height?: number;
	showValues?: boolean;
	showGrid?: boolean;
	class?: string;
}

const { data, height = 200, showValues = true, showGrid = true, className } = Astro.props;

const maxValue = Math.max(...data.map(d => d.value));
const defaultColors = ['bg-teal-400', 'bg-cyan-400', 'bg-orange-400', 'bg-blue-400', 'bg-purple-400'];
---

<div class={`w-full ${className || ''}`}>
	<div class="flex items-end justify-between gap-2 md:gap-4 h-64 md:h-80" style={`height: ${height}px`}>
		{data.map((item, index) => {
			const barHeight = (item.value / maxValue) * 100;
			const color = item.color || defaultColors[index % defaultColors.length];
			
			return (
				<div class="flex flex-col items-center flex-1 group cursor-pointer">
					<!-- Bar Container -->
					<div class="relative w-full max-w-[60px] flex items-end justify-center">
						<!-- Bar -->
						<div 
							class={`w-full rounded-t-2xl transition-all duration-700 ease-out transform origin-bottom group-hover:brightness-110 ${color}`}
							style={`height: 0px`}
							data-height={`${barHeight}%`}
						>
							<!-- Tooltip on hover -->
							<div class="absolute -top-10 left-1/2 -translate-x-1/2 px-3 py-1.5 bg-gray-900 text-white text-xs font-medium rounded-lg opacity-0 group-hover:opacity-100 transition-opacity duration-200 whitespace-nowrap pointer-events-none z-10">
								{item.value.toLocaleString()}
							</div>
						</div>
					</div>
					
					<!-- Label -->
					<div class="mt-3 text-xs font-medium text-gray-500 text-center truncate w-full">
						{item.label}
					</div>
				</div>
			);
		})}
	</div>
	
	<!-- Grid Lines -->
	{showGrid && (
		<div class="relative -mt-32 h-32 pointer-events-none" style={`height: ${height * 0.5}px`}>
			<div class="absolute inset-0 border-t border-gray-200 border-dashed opacity-30"></div>
			<div class="absolute bottom-0 left-0 right-0 border-b border-gray-200 border-dashed opacity-30"></div>
		</div>
	)}
</div>

<script>
document.addEventListener('DOMContentLoaded', () => {
	const bars = document.querySelectorAll('[data-height]');
	bars.forEach((bar, index) => {
		setTimeout(() => {
			bar.style.height = bar.getAttribute('data-height');
		}, index * 100);
	});
});
</script>
