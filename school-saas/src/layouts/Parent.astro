---
import Base from './Base.astro';
import Nav from '../components/Nav.astro';

export interface Props {
	title: string;
}

const { title } = Astro.props;
---

<Base title={title}>
	<Nav userRole="parent" />
	
	<div class="flex h-screen bg-gray-50">
		<!-- Sidebar -->
		<aside class="w-64 bg-white shadow-md">
			<div class="p-4">
				<h2 class="text-xl font-bold text-gray-800 mb-6">Parent Portal</h2>
				<nav class="space-y-2">
					<a href="/dashboard" class="block px-4 py-2 text-gray-700 hover:bg-gray-100 rounded transition-colors">
						📊 Dashboard
					</a>
					<a href="/students" class="block px-4 py-2 text-gray-700 hover:bg-gray-100 rounded transition-colors">
						👥 My Children
					</a>
					<a href="/attendance" class="block px-4 py-2 text-gray-700 hover:bg-gray-100 rounded transition-colors">
						📅 Attendance Records
					</a>
					<a href="/grades" class="block px-4 py-2 text-gray-700 hover:bg-gray-100 rounded transition-colors">
						📝 Grades & Reports
					</a>
					<hr class="my-4">
					<a href="/reports" class="block px-4 py-2 text-gray-700 hover:bg-gray-100 rounded transition-colors">
						📈 Progress Reports
					</a>
					<a href="/notifications" class="block px-4 py-2 text-gray-700 hover:bg-gray-100 rounded transition-colors">
						🔔 Notifications
					</a>
					<a href="/profile" class="block px-4 py-2 text-gray-700 hover:bg-gray-100 rounded transition-colors">
						👤 Profile
					</a>
				</nav>
			</div>
		</aside>
		
		<!-- Main Content -->
		<main class="flex-1 overflow-y-auto">
			<div class="p-6">
				<slot />
			</div>
		</main>
	</div>
</Base>
