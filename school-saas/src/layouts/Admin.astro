---
import Base from './Base.astro';
import Sidebar from '../components/Sidebar.astro';
import TopNavbar from '../components/TopNavbar.astro';

export interface Props {
	title: string;
	userName?: string;
	userRole: 'admin' | 'teacher' | 'parent';
	schoolName?: string;
}

const { title, userName = 'Admin User', userRole, schoolName = 'EduSchool' } = Astro.props;
---

<Base title={title}>
	<div class="flex h-screen bg-beige-100 overflow-hidden">
		<!-- Sidebar -->
		<Sidebar userRole={userRole} userName={userName} schoolName={schoolName} />
		
		<!-- Main Content Area -->
		<div class="flex-1 flex flex-col overflow-hidden">
			<!-- Top Navigation -->
			<TopNavbar userName={userName} userRole={userRole} />
			
			<!-- Page Content -->
			<main class="flex-1 overflow-y-auto bg-beige-100 p-4 md:p-6 lg:p-8">
				<div class="max-w-7xl mx-auto space-y-6 md:space-y-8 animate-fade-in">
					<slot />
				</div>
			</main>
		</div>
	</div>
</Base>
