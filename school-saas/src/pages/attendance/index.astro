---
import Layout from '../../layouts/Base.astro';
import { getAuthFromCookie } from '../../lib/auth';

// Get user from cookie
const user = getAuthFromCookie(Astro.cookies);

if (!user) {
  return Astro.redirect('/?error=not_authenticated');
}

// Get URL parameters
const url = new URL(Astro.request.url);
const classId = url.searchParams.get('classId') || '';
const date = url.searchParams.get('date') || new Date().toISOString().split('T')[0];

// Get attendance and classes data
let attendanceData = [];
let classes = [];
let students = [];
let error = null;

try {
  // Get classes (for teachers, only their classes)
  const classesUrl = user.role === 'teacher' 
    ? `${import.meta.env.PUBLIC_API_URL}/api/classes?teacherId=${user.id}`
    : `${import.meta.env.PUBLIC_API_URL}/api/classes`;
  
  const classesResponse = await fetch(classesUrl, {
    headers: {
      'Cookie': Astro.request.headers.get('cookie') || ''
    }
  });
  
  if (classesResponse.ok) {
    const classesData = await classesResponse.json();
    classes = classesData.classes || classesData || [];
  }

  // Get attendance data
  const attendanceUrl = `${import.meta.env.PUBLIC_API_URL}/api/attendance?date=${date}${classId ? '&classId=' + classId : ''}`;
  const attendanceResponse = await fetch(attendanceUrl, {
    headers: {
      'Cookie': Astro.request.headers.get('cookie') || ''
    }
  });
  
  if (attendanceResponse.ok) {
    const attendanceResult = await attendanceResponse.json();
    attendanceData = attendanceResult || [];
  }

  // Get students for the selected class
  if (classId) {
    const studentsUrl = `${import.meta.env.PUBLIC_API_URL}/api/students`;
    const studentsResponse = await fetch(studentsUrl, {
      headers: {
        'Cookie': Astro.request.headers.get('cookie') || ''
      }
    });
    
    if (studentsResponse.ok) {
      const studentsResult = await studentsResponse.json();
      students = studentsResult.students || [];
    }
  }

} catch (err) {
  console.error('Error fetching attendance data:', err);
  error = 'Error loading attendance data';
}

// Determine layout based on role
let roleLayout;
switch (user.role) {
  case 'admin':
    roleLayout = '../../layouts/Admin.astro';
    break;
  case 'teacher':
    roleLayout = '../../layouts/Teacher.astro';
    break;
  case 'parent':
    roleLayout = '../../layouts/Parent.astro';
    break;
  default:
    roleLayout = '../../layouts/Base.astro';
}

const LayoutComponent = await import(roleLayout);
const RoleLayout = LayoutComponent.default;
---

<RoleLayout title="Attendance - School Management System">
  <div class="space-y-6">
    <!-- Header -->
    <div class="bg-white rounded-lg shadow-md p-6">
      <div class="flex justify-between items-center">
        <div>
          <h1 class="text-2xl font-bold text-gray-900">Attendance</h1>
          <p class="text-gray-600 mt-1">
            Track and manage student attendance
          </p>
        </div>
        <div class="flex items-center space-x-2">
          <div id="sync-status" class="w-2 h-2 bg-green-500 rounded-full" title="All changes saved"></div>
          <span class="text-sm text-gray-500">Auto-save enabled</span>
        </div>
      </div>
    </div>

    <!-- Date and Class Selection -->
    <div class="bg-white rounded-lg shadow-md p-6">
      <form class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <div>
          <label for="date" class="block text-sm font-medium text-gray-700 mb-2">
            Date
          </label>
          <input 
            type="date" 
            id="date" 
            name="date"
            value={date}
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
            hx-get="/attendance"
            hx-target="#attendance-content"
            hx-include="select[name='classId']"
            hx-trigger="change"
          />
        </div>
        
        <div>
          <label for="classId" class="block text-sm font-medium text-gray-700 mb-2">
            Class
          </label>
          <select 
            id="classId" 
            name="classId"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
            hx-get="/attendance"
            hx-target="#attendance-content"
            hx-include="input[name='date']"
            hx-trigger="change"
          >
            <option value="">All Classes</option>
            {classes.map((classItem) => (
              <option value={classItem.id} selected={classItem.id === classId}>
                {classItem.name} - {classItem.subject} (Grade {classItem.grade_level})
              </option>
            ))}
          </select>
        </div>
        
        <div class="flex items-end">
          <button 
            type="button"
            class="w-full px-4 py-2 bg-blue-600 text-white hover:bg-blue-700 rounded-md transition-colors"
            onclick="printAttendance()"
          >
            Print Report
          </button>
        </div>
      </form>
    </div>

    <!-- Attendance Content -->
    <div id="attendance-content">
      {error ? (
        <div class="bg-red-50 border border-red-200 rounded-md p-4">
          <div class="flex">
            <div class="flex-shrink-0">
              <svg class="h-5 w-5 text-red-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
              </svg>
            </div>
            <div class="ml-3">
              <h3 class="text-sm font-medium text-red-800">Error</h3>
              <p class="mt-1 text-sm text-red-700">{error}</p>
            </div>
          </div>
        </div>
      ) : !classId ? (
        <!-- Show attendance summary for all classes -->
        <div class="bg-white rounded-lg shadow-md p-6">
          <h3 class="text-lg font-semibold text-gray-900 mb-4">
            Attendance Summary - {new Date(date).toLocaleDateString()}
          </h3>
          
          {attendanceData.length > 0 ? (
            <div class="space-y-4">
              {attendanceData.map((record) => (
                <div class="border border-gray-200 rounded-lg p-4">
                  <div class="flex justify-between items-center">
                    <div>
                      <h4 class="font-medium text-gray-900">
                        {record.students?.first_name} {record.students?.last_name}
                      </h4>
                      <p class="text-sm text-gray-500">
                        {record.classes?.name} - {record.classes?.subject}
                      </p>
                    </div>
                    <div class="flex items-center space-x-2">
                      <span class={`px-2 py-1 inline-flex text-xs leading-5 font-semibold rounded-full ${
                        record.status === 'present' ? 'bg-green-100 text-green-800' :
                        record.status === 'absent' ? 'bg-red-100 text-red-800' :
                        record.status === 'late' ? 'bg-yellow-100 text-yellow-800' :
                        'bg-blue-100 text-blue-800'
                      }`}>
                        {record.status.charAt(0).toUpperCase() + record.status.slice(1)}
                      </span>
                      {(user.role === 'admin' || user.role === 'teacher') && (
                        <button 
                          class="text-indigo-600 hover:text-indigo-900 text-sm"
                          hx-get={`/attendance/edit?id=${record.id}`}
                          hx-target="#modal-content"
                          hx-trigger="click"
                        >
                          Edit
                        </button>
                      )}
                    </div>
                  </div>
                </div>
              ))}
            </div>
          ) : (
            <div class="text-center py-8 text-gray-500">
              <svg class="w-12 h-12 text-gray-400 mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
              </svg>
              <p class="text-lg font-medium">No attendance records found</p>
              <p class="text-sm">Select a class to take attendance</p>
            </div>
          )}
        </div>
      ) : (
        <!-- Show attendance form for specific class -->
        <div class="bg-white rounded-lg shadow-md p-6">
          <div class="flex justify-between items-center mb-6">
            <h3 class="text-lg font-semibold text-gray-900">
              Take Attendance - {classes.find(c => c.id === classId)?.name || 'Class'}
            </h3>
            <div class="flex items-center space-x-4">
              <div class="text-sm text-gray-600">
                Date: {new Date(date).toLocaleDateString()}
              </div>
              <div id="save-status" class="text-sm text-gray-500">
                Ready to save changes
              </div>
            </div>
          </div>

          {students.length > 0 ? (
            <form 
              id="attendance-form"
              class="space-y-4"
            >
              <input type="hidden" name="class_id" value={classId} />
              <input type="hidden" name="date" value={date} />
              
              <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
                {students.map((student) => {
                  const currentAttendance = attendanceData.find(a => a.student_id === student.id);
                  return (
                    <div class="border border-gray-200 rounded-lg p-4 hover:bg-gray-50 transition-colors">
                      <div class="flex items-center justify-between mb-3">
                        <div>
                          <h4 class="font-medium text-gray-900">
                            {student.first_name} {student.last_name}
                          </h4>
                          <p class="text-sm text-gray-500">Grade {student.grade_level}</p>
                        </div>
                      </div>
                      
                      <div class="space-y-2">
                        <label class="text-sm font-medium text-gray-700">Status:</label>
                        <div class="grid grid-cols-2 gap-2">
                          {['present', 'absent', 'late', 'excused'].map((status) => (
                            <label class="relative">
                              <input 
                                type="radio" 
                                name={`status_${student.id}`}
                                value={status}
                                checked={currentAttendance?.status === status}
                                class="peer sr-only"
                                onchange="updateAttendance('{student.id}', '{status}', '{classId}', '{date}')"
                              />
                              <div class={`
                                px-3 py-2 text-xs font-medium rounded-md cursor-pointer text-center transition-all
                                ${status === 'present' ? 'peer-checked:bg-green-100 peer-checked:text-green-800 hover:bg-green-50' : ''}
                                ${status === 'absent' ? 'peer-checked:bg-red-100 peer-checked:text-red-800 hover:bg-red-50' : ''}
                                ${status === 'late' ? 'peer-checked:bg-yellow-100 peer-checked:text-yellow-800 hover:bg-yellow-50' : ''}
                                ${status === 'excused' ? 'peer-checked:bg-blue-100 peer-checked:text-blue-800 hover:bg-blue-50' : ''}
                                ${currentAttendance?.status !== status ? 'bg-gray-100 text-gray-600' : ''}
                              `}>
                                {status.charAt(0).toUpperCase() + status.slice(1)}
                              </div>
                            </label>
                          ))}
                        </div>
                      </div>
                    </div>
                  );
                })}
              </div>
              
              <div class="mt-6 flex justify-between items-center">
                <div class="flex space-x-4 text-sm">
                  <div class="flex items-center">
                    <div class="w-3 h-3 bg-green-500 rounded-full mr-2"></div>
                    <span>Present: {students.filter(s => attendanceData.find(a => a.student_id === s.id)?.status === 'present').length}</span>
                  </div>
                  <div class="flex items-center">
                    <div class="w-3 h-3 bg-red-500 rounded-full mr-2"></div>
                    <span>Absent: {students.filter(s => attendanceData.find(a => a.student_id === s.id)?.status === 'absent').length}</span>
                  </div>
                  <div class="flex items-center">
                    <div class="w-3 h-3 bg-yellow-500 rounded-full mr-2"></div>
                    <span>Late: {students.filter(s => attendanceData.find(a => a.student_id === s.id)?.status === 'late').length}</span>
                  </div>
                  <div class="flex items-center">
                    <div class="w-3 h-3 bg-blue-500 rounded-full mr-2"></div>
                    <span>Excused: {students.filter(s => attendanceData.find(a => a.student_id === s.id)?.status === 'excused').length}</span>
                  </div>
                </div>
                
                <button 
                  type="button"
                  class="px-4 py-2 bg-blue-600 text-white hover:bg-blue-700 rounded-md transition-colors"
                  onclick="saveAllAttendance()"
                >
                  Save All Changes
                </button>
              </div>
            </form>
          ) : (
            <div class="text-center py-8 text-gray-500">
              <svg class="w-12 h-12 text-gray-400 mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" />
              </svg>
              <p class="text-lg font-medium">No students found</p>
              <p class="text-sm">This class has no enrolled students</p>
            </div>
          )}
        </div>
      )}
    </div>
  </div>

  <!-- Modal -->
  <div id="modal-container" class="hidden fixed inset-0 bg-gray-600 bg-opacity-50 overflow-y-auto h-full w-full z-50">
    <div class="relative top-20 mx-auto p-5 border w-96 shadow-lg rounded-md bg-white">
      <div class="mt-3">
        <div class="flex justify-between items-center mb-4">
          <h3 class="text-lg font-medium text-gray-900">Edit Attendance</h3>
          <button 
            class="text-gray-400 hover:text-gray-600"
            onclick="closeModal()"
          >
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
        </div>
        <div id="modal-content">
          <!-- Content will be loaded here -->
        </div>
      </div>
    </div>
  </div>

  <script>
    function updateAttendance(studentId, status, classId, date) {
      const statusEl = document.getElementById('save-status');
      statusEl.textContent = 'Saving...';
      statusEl.className = 'text-sm text-blue-600';
      
      fetch('/api/attendance', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify({
          student_id: studentId,
          class_id: classId,
          date: date,
          status: status
        })
      })
      .then(response => response.json())
      .then(data => {
        if (data.error) {
          statusEl.textContent = 'Error: ' + data.error;
          statusEl.className = 'text-sm text-red-600';
        } else {
          statusEl.textContent = 'Saved: ' + new Date().toLocaleTimeString();
          statusEl.className = 'text-sm text-green-600';
          
          // Update sync status
          const syncIndicator = document.getElementById('sync-status');
          syncIndicator.className = 'w-2 h-2 bg-green-500 rounded-full';
          
          setTimeout(() => {
            statusEl.textContent = 'All changes saved';
            statusEl.className = 'text-sm text-gray-500';
          }, 3000);
        }
      })
      .catch(error => {
        console.error('Error:', error);
        statusEl.textContent = 'Error saving attendance';
        statusEl.className = 'text-sm text-red-600';
      });
    }

    function saveAllAttendance() {
      const form = document.getElementById('attendance-form');
      const classId = form.querySelector('input[name="class_id"]').value;
      const date = form.querySelector('input[name="date"]').value;
      
      const statusInputs = form.querySelectorAll('input[type="radio"]:checked');
      let savePromises = [];
      
      statusInputs.forEach(input => {
        const studentId = input.name.replace('status_', '');
        const status = input.value;
        savePromises.push(
          fetch('/api/attendance', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
            },
            body: JSON.stringify({
              student_id: studentId,
              class_id: classId,
              date: date,
              status: status
            })
          })
        );
      });
      
      Promise.all(savePromises).then(() => {
        const statusEl = document.getElementById('save-status');
        statusEl.textContent = 'All attendance saved successfully';
        statusEl.className = 'text-sm text-green-600';
      });
    }

    function closeModal() {
      document.getElementById('modal-container').classList.add('hidden');
    }

    function printAttendance() {
      window.print();
    }

    // Close modal when clicking outside
    document.getElementById('modal-container').addEventListener('click', function(e) {
      if (e.target === this) {
        closeModal();
      }
    });
  </script>
</RoleLayout>
