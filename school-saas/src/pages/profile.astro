---
import Layout from '../layouts/Base.astro';
import { getAuthFromCookie } from '../lib/auth';

// Get user from cookie
const user = getAuthFromCookie(Astro.cookies);

if (!user) {
  return Astro.redirect('/?error=not_authenticated');
}

import AdminLayout from '../layouts/Admin.astro';
import TeacherLayout from '../layouts/Teacher.astro';
import ParentLayout from '../layouts/Parent.astro';

const layouts = {
  admin: AdminLayout,
  teacher: TeacherLayout,
  parent: ParentLayout,
  default: Layout
};

const RoleLayout = layouts[user.role as keyof typeof layouts] || layouts.default;
---

<RoleLayout title={`Profile - ${user.first_name} ${user.last_name}`}>
  <div class="max-w-4xl mx-auto">
    <div class="bg-white shadow rounded-lg overflow-hidden">
      <!-- Profile Header -->
      <div class="bg-blue-600 h-32"></div>
      <div class="px-6 pb-6">
        <div class="relative flex justify-between items-end -mt-12 mb-6">
          <div class="flex items-end">
            <div class="h-24 w-24 rounded-full border-4 border-white bg-blue-100 flex items-center justify-center text-3xl font-bold text-blue-600 shadow-sm">
              {user.first_name.charAt(0)}{user.last_name.charAt(0)}
            </div>
            <div class="ml-4 mb-2">
              <h1 class="text-2xl font-bold text-gray-900">{user.first_name} {user.last_name}</h1>
              <p class="text-gray-500 capitalize">{user.role}</p>
            </div>
          </div>
          <button 
            hx-delete="/api/auth"
            hx-trigger="click"
            class="px-4 py-2 bg-red-600 text-white rounded-md hover:bg-red-700 transition-colors"
          >
            Log Out
          </button>
        </div>

        <!-- Profile Details -->
        <div class="border-t border-gray-200 pt-6">
          <h2 class="text-lg font-semibold text-gray-900 mb-4">Account Information</h2>
          <dl class="grid grid-cols-1 md:grid-cols-2 gap-x-4 gap-y-6">
            <div>
              <dt class="text-sm font-medium text-gray-500">Email Address</dt>
              <dd class="mt-1 text-sm text-gray-900 font-medium">{user.email}</dd>
            </div>
            <div>
              <dt class="text-sm font-medium text-gray-500">School ID</dt>
              <dd class="mt-1 text-sm text-gray-900 font-medium font-mono">{user.school_id || 'Not Assigned'}</dd>
            </div>
            <div>
              <dt class="text-sm font-medium text-gray-500">Account Role</dt>
              <dd class="mt-1 text-sm text-gray-900 capitalize font-medium">{user.role}</dd>
            </div>
            <div>
              <dt class="text-sm font-medium text-gray-500">Member Since</dt>
              <dd class="mt-1 text-sm text-gray-900 font-medium">Recently Joined</dd>
            </div>
          </dl>
        </div>

        <div class="border-t border-gray-200 mt-8 pt-6">
          <h2 class="text-lg font-semibold text-gray-900 mb-4">Privacy & Security</h2>
          <div class="space-y-4">
            <button class="text-blue-600 hover:text-blue-800 text-sm font-medium">
              Change Password
            </button>
            <br>
            <button class="text-blue-600 hover:text-blue-800 text-sm font-medium">
              Enable Two-Factor Authentication
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script>
    // Handle logout response
    document.addEventListener('htmx:afterRequest', function(evt) {
      if (evt.detail.xhr.status === 200 && evt.detail.requestConfig.path === '/api/auth' && evt.detail.requestConfig.method === 'DELETE') {
        window.location.href = '/';
      }
    });
  </script>
</RoleLayout>
