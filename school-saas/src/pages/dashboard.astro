---
import AdminLayout from '../layouts/Admin.astro';
import StatCard from '../components/ui/StatCard.astro';
import Card from '../components/ui/Card.astro';
import RevenueWidget from '../components/widgets/RevenueWidget.astro';
import EnrollmentWidget from '../components/widgets/EnrollmentWidget.astro';
import AttendanceWidget from '../components/widgets/AttendanceWidget.astro';
import TeacherPerformance from '../components/widgets/TeacherPerformance.astro';
import AnnouncementsWidget from '../components/widgets/AnnouncementsWidget.astro';
import UpcomingEvents from '../components/widgets/UpcomingEvents.astro';
import FeeTracker from '../components/widgets/FeeTracker.astro';
import StudentPerformance from '../components/widgets/StudentPerformance.astro';
import RecentActivity from '../components/widgets/RecentActivity.astro';
import { getAuthFromCookie } from '../lib/auth';

// Get user from cookie
const user = getAuthFromCookie(Astro.cookies);

if (!user) {
	return Astro.redirect('/?error=not_authenticated');
}

// Fetch user data
let userData = null;
try {
	const response = await fetch(`${Astro.url.origin}/api/me`, {
		headers: {
			'Cookie': Astro.request.headers.get('cookie') || ''
		}
	});
	
	if (response.ok) {
		userData = await response.json();
	}
} catch (error) {
	console.error('Error fetching user data:', error);
}

// Mock data for premium dashboard display
const revenueData = {
	totalRevenue: 2450000,
	monthlyGrowth: 12.5,
	recentTransactions: [
		{ id: '1', description: 'Tuition Fee - Grade 10-A', amount: 425000, status: 'completed', date: 'Feb 10, 2024' },
		{ id: '2', description: 'Transport Fee Collection', amount: 125000, status: 'completed', date: 'Feb 9, 2024' },
		{ id: '3', description: 'Library Fee - Grade 8-B', amount: 45000, status: 'pending', date: 'Feb 9, 2024' },
		{ id: '4', description: 'Sports Fee - Grade 11', amount: 85000, status: 'completed', date: 'Feb 8, 2024' },
	]
};

const attendanceStats = {
	totalStudents: 1247,
	presentToday: 1189,
	attendanceRate: 95.3,
	classes: [
		{ name: 'Grade 1-A', total: 32, present: 31, rate: 97 },
		{ name: 'Grade 1-B', total: 30, present: 29, rate: 97 },
		{ name: 'Grade 2-A', total: 28, present: 26, rate: 93 },
		{ name: 'Grade 3-A', total: 35, present: 34, rate: 97 },
		{ name: 'Grade 4-A', total: 30, present: 28, rate: 93 },
	]
};

const announcements = [
	{ 
		id: '1', 
		title: 'Parent-Teacher Meeting Scheduled for February 15th', 
		excerpt: 'All parents are requested to attend the quarterly progress review meeting.',
		author: 'Principal Smith', 
		date: '2 hours ago',
		type: 'event' as const,
		priority: 'high' as const
	},
	{ 
		id: '2', 
		title: 'Science Fair Registration Now Open', 
		excerpt: 'Students from grades 6-12 can register for the annual science fair.',
		author: 'Science Dept', 
		date: '1 day ago',
		type: 'academic' as const,
		priority: 'medium' as const
	},
	{ 
		id: '3', 
		title: 'Winter Break Extended Due to Weather', 
		excerpt: 'School will remain closed until further notice.',
		author: 'Admin Office', 
		date: '2 days ago',
		type: 'urgent' as const,
		priority: 'high' as const
	},
	{ 
		id: '4', 
		title: 'New Online Learning Platform Launch', 
		excerpt: 'We are excited to announce our new digital learning platform.',
		author: 'IT Department', 
		date: '3 days ago',
		type: 'general' as const,
		priority: 'low' as const
	}
];

const recentActivity = [
	{
		id: '1',
		user: { name: 'Sarah Johnson', role: 'Teacher' },
		action: 'submitted grades for',
		target: 'Mathematics - Grade 10',
		timestamp: new Date(Date.now() - 1000 * 60 * 30).toISOString(),
		type: 'grade' as const,
		details: 'Final exam scores uploaded'
	},
	{
		id: '2',
		user: { name: 'Michael Chen', role: 'Teacher' },
		action: 'marked attendance for',
		timestamp: new Date(Date.now() - 1000 * 60 * 60 * 2).toISOString(),
		type: 'attendance' as const,
		details: 'Grade 9-B - 27/30 present'
	},
	{
		id: '3',
		user: { name: 'Emma Thompson', role: 'Parent' },
		action: 'paid fees for',
		target: 'Spring Semester',
		timestamp: new Date(Date.now() - 1000 * 60 * 60 * 4).toISOString(),
		type: 'payment' as const,
		details: 'Rs. 125,000 via online transfer'
	},
	{
		id: '4',
		user: { name: 'System', role: 'Admin' },
		action: 'backed up database',
		timestamp: new Date(Date.now() - 1000 * 60 * 60 * 6).toISOString(),
		type: 'system' as const,
		details: 'Daily automated backup completed'
	},
	{
		id: '5',
		user: { name: 'Lisa Garcia', role: 'Teacher' },
		action: 'created assignment',
		target: 'Biology Lab Report',
		timestamp: new Date(Date.now() - 1000 * 60 * 60 * 8).toISOString(),
		type: 'announcement' as const,
		details: 'Due date: Feb 20, 2024'
	}
];
---

<AdminLayout 
	title="Dashboard" 
	userName={`${user.first_name} ${user.last_name}`} 
	userRole={user.role}
>
	<!-- Welcome Header -->
	<div class="mb-8 animate-slide-up">
		<h1 class="text-3xl font-heading font-bold text-gray-900 mb-2">
			Welcome back, {user.first_name}!
		</h1>
		<p class="text-gray-600">
			Here's what's happening at your school today.
		</p>
	</div>

	<!-- KPI Stats Row -->
	<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 md:gap-6 mb-8 animate-slide-up" style="animation-delay: 0.1s">
		<StatCard 
			label="Total Revenue" 
			value={`Rs.${(revenueData.totalRevenue / 100000).toFixed(1)}L`} 
			trend={{ value: revenueData.monthlyGrowth, isPositive: true }}
			variant="teal"
		>
			<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
				<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
			</svg>
		</StatCard>
		
		<StatCard 
			label="Total Students" 
			value={userData?.stats?.totalStudents || 1247} 
			trend={{ value: 8, isPositive: true }}
			variant="cyan"
		>
			<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
				<path d="M16 21v-2a4 4 0 00-4-4H6a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/>
			</svg>
		</StatCard>
		
		<StatCard 
			label="Attendance Rate" 
			value={`${attendanceStats.attendanceRate}%`} 
			trend={{ value: 2.3, isPositive: true }}
			variant="orange"
		>
			<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
				<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
			</svg>
		</StatCard>
		
		<StatCard 
			label="Total Teachers" 
			value={userData?.stats?.totalTeachers || 48} 
			trend={{ value: 4, isPositive: true }}
			variant="blue"
		>
			<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
				<path d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
			</svg>
		</StatCard>
	</div>

	<!-- Main Dashboard Grid -->
	<div class="grid grid-cols-1 lg:grid-cols-3 gap-6 md:gap-8">
		
		<!-- Left Column - 2/3 width -->
		<div class="lg:col-span-2 space-y-6 md:space-y-8">
			<!-- Revenue Widget -->
			<div class="animate-slide-up" style="animation-delay: 0.2s">
				<RevenueWidget 
					totalRevenue={revenueData.totalRevenue}
					monthlyGrowth={revenueData.monthlyGrowth}
					recentTransactions={revenueData.recentTransactions}
				/>
			</div>
			
			<!-- Enrollment & Attendance Row -->
			<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
				<div class="animate-slide-up" style="animation-delay: 0.3s">
					<EnrollmentWidget />
				</div>
				<div class="animate-slide-up" style="animation-delay: 0.35s">
					<AttendanceWidget 
						totalStudents={attendanceStats.totalStudents}
						presentToday={attendanceStats.presentToday}
						attendanceRate={attendanceStats.attendanceRate}
						classes={attendanceStats.classes}
					/>
				</div>
			</div>
			
			<!-- Student Performance -->
			<div class="animate-slide-up" style="animation-delay: 0.4s">
				<StudentPerformance />
			</div>
		</div>
		
		<!-- Right Column - 1/3 width -->
		<div class="space-y-6 md:space-y-8">
			<!-- Teacher Performance -->
			<div class="animate-slide-up" style="animation-delay: 0.3s">
				<TeacherPerformance />
			</div>
			
			<!-- Announcements -->
			<div class="animate-slide-up" style="animation-delay: 0.35s">
				<AnnouncementsWidget announcements={announcements} />
			</div>
			
			<!-- Upcoming Events -->
			<div class="animate-slide-up" style="animation-delay: 0.4s">
				<UpcomingEvents />
			</div>
			
			<!-- Fee Tracker -->
			<div class="animate-slide-up" style="animation-delay: 0.45s">
				<FeeTracker />
			</div>
		</div>
	</div>
	
	<!-- Recent Activity - Full Width -->
	<div class="mt-8 animate-slide-up" style="animation-delay: 0.5s">
		<RecentActivity activities={recentActivity} />
	</div>
</AdminLayout>

<style is:global>
	/* Premium Font Import - Poppins */
	@import url('https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&family=Inter:wght@300;400;500;600;700&display=swap');
	
	.font-heading {
		font-family: 'Poppins', sans-serif;
	}
	
	/* Smooth scroll behavior */
	html {
		scroll-behavior: smooth;
	}
	
	/* Custom scrollbar */
	::-webkit-scrollbar {
		width: 8px;
		height: 8px;
	}
	
	::-webkit-scrollbar-track {
		background: #f1f1f1;
		border-radius: 4px;
	}
	
	::-webkit-scrollbar-thumb {
		background: #c1c1c1;
		border-radius: 4px;
	}
	
	::-webkit-scrollbar-thumb:hover {
		background: #a1a1a1;
	}
	
	/* Line clamp utility */
	.line-clamp-1 {
		display: -webkit-box;
		-webkit-line-clamp: 1;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}
	
	.line-clamp-2 {
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}
</style>
