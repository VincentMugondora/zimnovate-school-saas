---
import Layout from '../layouts/Base.astro';
import { getAuthFromCookie } from '../lib/auth';

// Get user from cookie
const user = getAuthFromCookie(Astro.cookies);

if (!user) {
  return Astro.redirect('/?error=not_authenticated');
}

// Get user-specific data
let userData = null;
let stats = {};
let recentActivity = [];

try {
  const response = await fetch(`${import.meta.env.PUBLIC_API_URL}/api/me`, {
    headers: {
      'Cookie': Astro.request.headers.get('cookie') || ''
    }
  });
  
  if (response.ok) {
    userData = await response.json();
  }
} catch (error) {
  console.error('Error fetching user data:', error);
}

// Determine layout based on role
let roleLayout;
switch (user.role) {
  case 'admin':
    roleLayout = '../layouts/Admin.astro';
    break;
  case 'teacher':
    roleLayout = '../layouts/Teacher.astro';
    break;
  case 'parent':
    roleLayout = '../layouts/Parent.astro';
    break;
  default:
    roleLayout = '../layouts/Base.astro';
}

const LayoutComponent = await import(roleLayout);
const RoleLayout = LayoutComponent.default;
---

<RoleLayout title={`Dashboard - ${user.first_name} ${user.last_name}`}>
  <div class="space-y-6">
    <!-- Welcome Header -->
    <div class="bg-white rounded-lg shadow-md p-6">
      <h1 class="text-2xl font-bold text-gray-900 mb-2">
        Welcome back, {user.first_name}!
      </h1>
      <p class="text-gray-600">
        Here's what's happening at your school today.
      </p>
    </div>

    <!-- Role-specific Dashboard Content -->
    {user.role === 'admin' && (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        <!-- Stats Cards -->
        <div class="bg-white rounded-lg shadow-md p-6">
          <div class="flex items-center">
            <div class="p-3 rounded-full bg-blue-100 text-blue-600">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" />
              </svg>
            </div>
            <div class="ml-4">
              <p class="text-sm font-medium text-gray-600">Total Students</p>
              <p class="text-2xl font-bold text-gray-900">{userData?.stats?.totalStudents || 0}</p>
            </div>
          </div>
        </div>

        <div class="bg-white rounded-lg shadow-md p-6">
          <div class="flex items-center">
            <div class="p-3 rounded-full bg-green-100 text-green-600">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
              </svg>
            </div>
            <div class="ml-4">
              <p class="text-sm font-medium text-gray-600">Total Classes</p>
              <p class="text-2xl font-bold text-gray-900">{userData?.stats?.totalClasses || 0}</p>
            </div>
          </div>
        </div>

        <div class="bg-white rounded-lg shadow-md p-6">
          <div class="flex items-center">
            <div class="p-3 rounded-full bg-purple-100 text-purple-600">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
              </svg>
            </div>
            <div class="ml-4">
              <p class="text-sm font-medium text-gray-600">Total Teachers</p>
              <p class="text-2xl font-bold text-gray-900">{userData?.stats?.totalTeachers || 0}</p>
            </div>
          </div>
        </div>

        <div class="bg-white rounded-lg shadow-md p-6">
          <div class="flex items-center">
            <div class="p-3 rounded-full bg-yellow-100 text-yellow-600">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <div class="ml-4">
              <p class="text-sm font-medium text-gray-600">Today's Attendance</p>
              <p class="text-2xl font-bold text-gray-900">92%</p>
            </div>
          </div>
        </div>
      </div>
    )}

    {user.role === 'teacher' && (
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <!-- My Classes -->
        <div class="lg:col-span-2">
          <div class="bg-white rounded-lg shadow-md p-6">
            <h2 class="text-lg font-semibold text-gray-900 mb-4">My Classes</h2>
            <div class="space-y-4">
              {userData?.classes?.length > 0 ? (
                userData.classes.map((classItem) => (
                  <div class="border border-gray-200 rounded-lg p-4 hover:bg-gray-50 transition-colors">
                    <div class="flex justify-between items-center">
                      <div>
                        <h3 class="font-medium text-gray-900">{classItem.name}</h3>
                        <p class="text-sm text-gray-500">{classItem.subject} • Grade {classItem.grade_level}</p>
                      </div>
                      <div class="flex space-x-2">
                        <a 
                          href={`/attendance?classId=${classItem.id}`}
                          class="px-3 py-1 text-sm bg-blue-100 text-blue-800 rounded-md hover:bg-blue-200 transition-colors"
                        >
                          Take Attendance
                        </a>
                        <a 
                          href={`/grades?classId=${classItem.id}`}
                          class="px-3 py-1 text-sm bg-green-100 text-green-800 rounded-md hover:bg-green-200 transition-colors"
                        >
                          Manage Grades
                        </a>
                      </div>
                    </div>
                  </div>
                ))
              ) : (
                <div class="text-center py-8 text-gray-500">
                  <svg class="w-12 h-12 text-gray-400 mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
                  </svg>
                  <p>No classes assigned yet</p>
                </div>
              )}
            </div>
          </div>
        </div>

        <!-- Quick Actions -->
        <div>
          <div class="bg-white rounded-lg shadow-md p-6">
            <h2 class="text-lg font-semibold text-gray-900 mb-4">Quick Actions</h2>
            <div class="space-y-3">
              <a 
                href="/attendance"
                class="block w-full text-center px-4 py-2 bg-blue-600 text-white rounded-md hover:bg-blue-700 transition-colors"
              >
                Take Attendance
              </a>
              <a 
                href="/grades"
                class="block w-full text-center px-4 py-2 bg-green-600 text-white rounded-md hover:bg-green-700 transition-colors"
              >
                Enter Grades
              </a>
              <a 
                href="/students"
                class="block w-full text-center px-4 py-2 bg-purple-600 text-white rounded-md hover:bg-purple-700 transition-colors"
              >
                View Students
              </a>
            </div>
          </div>
        </div>
      </div>
    )}

    {user.role === 'parent' && (
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <!-- Children Overview -->
        <div class="lg:col-span-2">
          <div class="bg-white rounded-lg shadow-md p-6">
            <h2 class="text-lg font-semibold text-gray-900 mb-4">My Children</h2>
            <div class="space-y-4">
              {userData?.children?.length > 0 ? (
                userData.children.map((child) => (
                  <div class="border border-gray-200 rounded-lg p-4 hover:bg-gray-50 transition-colors">
                    <div class="flex justify-between items-center">
                      <div>
                        <h3 class="font-medium text-gray-900">{child.first_name} {child.last_name}</h3>
                        <p class="text-sm text-gray-500">Grade {child.grade_level}</p>
                      </div>
                      <div class="flex space-x-2">
                        <a 
                          href={`/attendance?studentId=${child.id}`}
                          class="px-3 py-1 text-sm bg-blue-100 text-blue-800 rounded-md hover:bg-blue-200 transition-colors"
                        >
                          Attendance
                        </a>
                        <a 
                          href={`/grades?studentId=${child.id}`}
                          class="px-3 py-1 text-sm bg-green-100 text-green-800 rounded-md hover:bg-green-200 transition-colors"
                        >
                          Grades
                        </a>
                      </div>
                    </div>
                  </div>
                ))
              ) : (
                <div class="text-center py-8 text-gray-500">
                  <svg class="w-12 h-12 text-gray-400 mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" />
                  </svg>
                  <p>No children linked to your account</p>
                </div>
              )}
            </div>
          </div>
        </div>

        <!-- Recent Notifications -->
        <div>
          <div class="bg-white rounded-lg shadow-md p-6">
            <h2 class="text-lg font-semibold text-gray-900 mb-4">Recent Notifications</h2>
            <div class="space-y-3">
              <div class="flex items-start space-x-3">
                <div class="p-2 rounded-full bg-blue-100 text-blue-600">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                </div>
                <div>
                  <p class="text-sm font-medium text-gray-900">New grade posted</p>
                  <p class="text-xs text-gray-500">2 hours ago</p>
                </div>
              </div>
              <div class="flex items-start space-x-3">
                <div class="p-2 rounded-full bg-yellow-100 text-yellow-600">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                </div>
                <div>
                  <p class="text-sm font-medium text-gray-900">Attendance reminder</p>
                  <p class="text-xs text-gray-500">Yesterday</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    )}

    <!-- Recent Activity (Common for all roles) -->
    <div class="bg-white rounded-lg shadow-md p-6">
      <h2 class="text-lg font-semibold text-gray-900 mb-4">Recent Activity</h2>
      <div class="space-y-4">
        <div class="flex items-center space-x-3">
          <div class="p-2 rounded-full bg-gray-100 text-gray-600">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <div>
            <p class="text-sm text-gray-900">System initialized successfully</p>
            <p class="text-xs text-gray-500">Just now</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</RoleLayout>
