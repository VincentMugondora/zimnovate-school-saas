---
import Layout from '../../layouts/Base.astro';
import { getAuthFromCookie } from '../../lib/auth';

// Get user from cookie
const user = getAuthFromCookie(Astro.cookies);

if (!user) {
  return Astro.redirect('/?error=not_authenticated');
}

// Get classes data
let classes = [];
let error = null;

try {
  const apiUrl = user.role === 'teacher' 
    ? `${Astro.url.origin}/api/classes?teacherId=${user.id}`
    : `${Astro.url.origin}/api/classes`;
  
  const response = await fetch(apiUrl, {
    headers: {
      'Cookie': Astro.request.headers.get('cookie') || ''
    }
  });
  
  if (response.ok) {
    const data = await response.json();
    classes = data.classes || [];
  } else {
    error = 'Failed to fetch classes';
  }
} catch (err) {
  console.error('Error fetching classes:', err);
  error = 'Error loading classes';
}

import AdminLayout from '../../layouts/Admin.astro';
import TeacherLayout from '../../layouts/Teacher.astro';
import ParentLayout from '../../layouts/Parent.astro';

const layouts = {
  admin: AdminLayout,
  teacher: TeacherLayout,
  parent: ParentLayout,
  default: Layout
};

const RoleLayout = layouts[user.role as keyof typeof layouts] || layouts.default;
---

<RoleLayout title="My Classes - School Management System">
  <div class="space-y-6">
    <!-- Header -->
    <div class="bg-white rounded-lg shadow-md p-6">
      <div class="flex justify-between items-center">
        <div>
          <h1 class="text-2xl font-bold text-gray-900">My Classes</h1>
          <p class="text-gray-600 mt-1">
            Manage your teaching schedule and class assignments
          </p>
        </div>
        {user.role === 'admin' && (
          <button 
            class="px-4 py-2 bg-blue-600 text-white hover:bg-blue-700 rounded-md transition-colors"
          >
            Create New Class
          </button>
        )}
      </div>
    </div>

    <!-- Classes Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {error ? (
        <div class="col-span-full bg-red-50 border border-red-200 rounded-md p-4 text-red-700 text-center">
          {error}
        </div>
      ) : classes.length > 0 ? (
        classes.map((classItem) => (
          <div class="bg-white rounded-lg shadow-md hover:shadow-lg transition-shadow overflow-hidden border border-gray-100">
            <div class="bg-blue-600 h-2"></div>
            <div class="p-6">
              <div class="flex justify-between items-start mb-4">
                <div>
                  <h3 class="text-lg font-bold text-gray-900">{classItem.name}</h3>
                  <p class="text-sm text-gray-500 font-medium">{classItem.subject}</p>
                </div>
                <span class="bg-blue-100 text-blue-800 text-xs font-bold px-2.5 py-0.5 rounded-full">
                  Grade {classItem.grade_level}
                </span>
              </div>
              
              <div class="space-y-3 mb-6">
                <div class="flex items-center text-sm text-gray-600">
                  <svg class="w-4 h-4 mr-2 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                  </svg>
                  {classItem.users?.first_name ? `Teacher: ${classItem.users.first_name} ${classItem.users.last_name}` : 'No teacher assigned'}
                </div>
                <div class="flex items-center text-sm text-gray-600">
                  <svg class="w-4 h-4 mr-2 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                  Scheduled: Mon, Wed, Fri
                </div>
              </div>

              <div class="grid grid-cols-2 gap-3">
                <a 
                  href={`/attendance?classId=${classItem.id}`}
                  class="text-center px-3 py-2 text-sm font-medium text-blue-600 bg-blue-50 hover:bg-blue-100 rounded-md transition-colors"
                >
                  Attendance
                </a>
                <a 
                  href={`/grades?classId=${classItem.id}`}
                  class="text-center px-3 py-2 text-sm font-medium text-green-600 bg-green-50 hover:bg-green-100 rounded-md transition-colors"
                >
                  Grades
                </a>
              </div>
            </div>
          </div>
        ))
      ) : (
        <div class="col-span-full bg-white rounded-lg shadow-md p-12 text-center text-gray-500">
          <svg class="w-16 h-16 text-gray-300 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
          </svg>
          <h3 class="text-xl font-bold text-gray-900 mb-2">No Classes Found</h3>
          <p>You haven't been assigned to any classes yet.</p>
        </div>
      )}
    </div>
  </div>
</RoleLayout>
