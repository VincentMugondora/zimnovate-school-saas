---
import Layout from '../layouts/Base.astro';
import { getAuthFromCookie } from '../lib/auth';

// Get user from cookie
const user = getAuthFromCookie(Astro.cookies);

if (!user || user.role !== 'admin') {
  return Astro.redirect('/dashboard?error=unauthorized');
}

// Get users data
let users = [];
let error = null;

try {
  const apiUrl = `${Astro.url.origin}/api/users`;
  const response = await fetch(apiUrl, {
    headers: {
      'Cookie': Astro.request.headers.get('cookie') || ''
    }
  });
  
  if (response.ok) {
    const data = await response.json();
    users = data.users || [];
  } else {
    error = 'Failed to fetch users';
  }
} catch (err) {
  console.error('Error fetching users:', err);
  error = 'Error loading users';
}

import AdminLayout from '../layouts/Admin.astro';
const RoleLayout = AdminLayout;
---

<RoleLayout title="User Management - Admin Panel">
  <div class="space-y-6">
    <!-- Header -->
    <div class="bg-white rounded-lg shadow-md p-6">
      <div class="flex justify-between items-center">
        <div>
          <h1 class="text-2xl font-bold text-gray-900">User Management</h1>
          <p class="text-gray-600 mt-1">
            Manage teachers, parents, and administrative staff
          </p>
        </div>
        <button class="px-4 py-2 bg-blue-600 text-white hover:bg-blue-700 rounded-md transition-colors">
          Add New User
        </button>
      </div>
    </div>

    <!-- Users Table -->
    <div class="bg-white rounded-lg shadow-md overflow-hidden">
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200">
          <thead class="bg-gray-50">
            <tr>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">User</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Role</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Email</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
            </tr>
          </thead>
          <tbody class="bg-white divide-y divide-gray-200">
            {users.length > 0 ? (
              users.map((u) => (
                <tr class="hover:bg-gray-50 transition-colors">
                  <td class="px-6 py-4 whitespace-nowrap">
                    <div class="flex items-center">
                      <div class="h-10 w-10 rounded-full bg-gray-100 flex items-center justify-center text-gray-600 font-bold">
                        {u.first_name.charAt(0)}{u.last_name.charAt(0)}
                      </div>
                      <div class="ml-4">
                        <div class="text-sm font-medium text-gray-900">{u.first_name} {u.last_name}</div>
                        <div class="text-xs text-gray-500 font-mono">{u.id.substring(0, 8)}...</div>
                      </div>
                    </div>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap">
                    <span class={`px-2 py-1 inline-flex text-xs leading-5 font-semibold rounded-full ${
                      u.role === 'admin' ? 'bg-purple-100 text-purple-800' :
                      u.role === 'teacher' ? 'bg-blue-100 text-blue-800' :
                      'bg-green-100 text-green-800'
                    }`}>
                      {u.role}
                    </span>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                    {u.email}
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap">
                    <span class="px-2 py-1 inline-flex text-xs leading-5 font-semibold rounded-full bg-green-100 text-green-800">
                      Active
                    </span>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap text-sm font-medium">
                    <button class="text-blue-600 hover:text-blue-900 mr-3">Edit</button>
                    <button class="text-red-600 hover:text-red-900">Suspend</button>
                  </td>
                </tr>
              ))
            ) : (
              <tr>
                <td colspan="5" class="px-6 py-12 text-center text-gray-500">
                  {error || 'No users found.'}
                </td>
              </tr>
            )}
          </tbody>
        </table>
      </div>
    </div>
  </div>
</RoleLayout>
