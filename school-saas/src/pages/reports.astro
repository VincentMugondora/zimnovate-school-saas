---
import Layout from '../layouts/Base.astro';
import { getAuthFromCookie } from '../lib/auth';

// Get user from cookie
const user = getAuthFromCookie(Astro.cookies);

if (!user) {
  return Astro.redirect('/?error=not_authenticated');
}

import AdminLayout from '../layouts/Admin.astro';
import TeacherLayout from '../layouts/Teacher.astro';
import ParentLayout from '../layouts/Parent.astro';

const layouts = {
  admin: AdminLayout,
  teacher: TeacherLayout,
  parent: ParentLayout,
  default: Layout
};

const RoleLayout = layouts[user.role as keyof typeof layouts] || layouts.default;
---

<RoleLayout title="Academic Reports - School Management System">
  <div class="space-y-6">
    <!-- Header -->
    <div class="bg-white rounded-lg shadow-md p-6">
      <h1 class="text-2xl font-bold text-gray-900 mb-2">Academic Reports</h1>
      <p class="text-gray-600">
        Analyze school performance, attendance trends, and grade distributions.
      </p>
    </div>

    <!-- Reports Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <!-- Attendance Overview -->
      <div class="bg-white rounded-lg shadow-md p-6">
        <h3 class="text-lg font-semibold text-gray-900 mb-4">Attendance Overview</h3>
        <div class="h-64 flex items-end justify-between space-x-2 pb-2 border-b border-gray-200">
          <div class="bg-blue-500 w-full" style="height: 85%;"></div>
          <div class="bg-blue-500 w-full" style="height: 92%;"></div>
          <div class="bg-blue-500 w-full" style="height: 88%;"></div>
          <div class="bg-blue-500 w-full" style="height: 95%;"></div>
          <div class="bg-blue-500 w-full" style="height: 90%;"></div>
          <div class="bg-blue-500 w-full" style="height: 82%;"></div>
          <div class="bg-blue-500 w-full" style="height: 94%;"></div>
        </div>
        <div class="flex justify-between mt-2 text-xs text-gray-500">
          <span>Mon</span>
          <span>Tue</span>
          <span>Wed</span>
          <span>Thu</span>
          <span>Fri</span>
          <span>Sat</span>
          <span>Sun</span>
        </div>
        <p class="mt-4 text-sm text-center text-gray-600 font-medium">Average Weekly Attendance: 89.4%</p>
      </div>

      <!-- Grade Distribution -->
      <div class="bg-white rounded-lg shadow-md p-6">
        <h3 class="text-lg font-semibold text-gray-900 mb-4">Grade Distribution</h3>
        <div class="space-y-4">
          <div>
            <div class="flex justify-between text-sm mb-1">
              <span class="font-medium text-gray-700">Excellent (90-100)</span>
              <span class="text-gray-500">24%</span>
            </div>
            <div class="w-full bg-gray-200 rounded-full h-2">
              <div class="bg-green-500 h-2 rounded-full" style="width: 24%"></div>
            </div>
          </div>
          <div>
            <div class="flex justify-between text-sm mb-1">
              <span class="font-medium text-gray-700">Good (75-89)</span>
              <span class="text-gray-500">42%</span>
            </div>
            <div class="w-full bg-gray-200 rounded-full h-2">
              <div class="bg-blue-500 h-2 rounded-full" style="width: 42%"></div>
            </div>
          </div>
          <div>
            <div class="flex justify-between text-sm mb-1">
              <span class="font-medium text-gray-700">Satisfactory (50-74)</span>
              <span class="text-gray-500">28%</span>
            </div>
            <div class="w-full bg-gray-200 rounded-full h-2">
              <div class="bg-yellow-500 h-2 rounded-full" style="width: 28%"></div>
            </div>
          </div>
          <div>
            <div class="flex justify-between text-sm mb-1">
              <span class="font-medium text-gray-700">Needs Improvement (<50)</span>
              <span class="text-gray-500">6%</span>
            </div>
            <div class="w-full bg-gray-200 rounded-full h-2">
              <div class="bg-red-500 h-2 rounded-full" style="width: 6%"></div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Actions -->
    <div class="flex justify-end space-x-4">
      <button class="px-6 py-2 border border-gray-300 rounded-md text-gray-700 hover:bg-gray-50 transition-colors">
        Export PDF
      </button>
      <button class="px-6 py-2 bg-blue-600 text-white rounded-md hover:bg-blue-700 transition-colors">
        Generate Custom Report
      </button>
    </div>
  </div>
</RoleLayout>
