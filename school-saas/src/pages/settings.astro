---
import Layout from '../layouts/Base.astro';
import { getAuthFromCookie } from '../lib/auth';

// Get user from cookie
const user = getAuthFromCookie(Astro.cookies);

if (!user || user.role !== 'admin') {
  return Astro.redirect('/dashboard?error=unauthorized');
}

import AdminLayout from '../layouts/Admin.astro';
const RoleLayout = AdminLayout;
---

<RoleLayout title="Settings - Admin Panel">
  <div class="space-y-6">
    <!-- Header -->
    <div class="bg-white rounded-lg shadow-md p-6">
      <h1 class="text-2xl font-bold text-gray-900">System Settings</h1>
      <p class="text-gray-600 mt-1">Configure school-wide preferences and integration settings.</p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
      <!-- School Info -->
      <div class="lg:col-span-2 space-y-6">
        <div class="bg-white rounded-lg shadow-md p-6">
          <h3 class="text-lg font-bold text-gray-900 mb-4 border-b pb-2">School Profile</h3>
          <form class="space-y-4">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <div>
                <label class="block text-sm font-medium text-gray-700">School Name</label>
                <input type="text" class="mt-1 block w-full border border-gray-300 rounded-md shadow-sm p-2 focus:ring-blue-500 focus:border-blue-500" value="My School SaaS">
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700">Academic Year</label>
                <input type="text" class="mt-1 block w-full border border-gray-300 rounded-md shadow-sm p-2 focus:ring-blue-500 focus:border-blue-500" value="2025-2026">
              </div>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700">Contact Email</label>
              <input type="email" class="mt-1 block w-full border border-gray-300 rounded-md shadow-sm p-2" value="admin@myschool.com">
            </div>
            <button class="bg-blue-600 text-white px-4 py-2 rounded hover:bg-blue-700 transition-colors">Save Changes</button>
          </form>
        </div>

        <div class="bg-white rounded-lg shadow-md p-6">
          <h3 class="text-lg font-bold text-gray-900 mb-4 border-b pb-2">Notifications</h3>
          <div class="space-y-3">
            <div class="flex items-center justify-between">
              <div>
                <p class="font-medium text-gray-900">Attendance Alerts</p>
                <p class="text-sm text-gray-500">Notify parents when students are marked absent.</p>
              </div>
              <input type="checkbox" class="h-4 w-4 text-blue-600 focus:ring-blue-500 border-gray-300 rounded" checked>
            </div>
            <div class="flex items-center justify-between border-t pt-3">
              <div>
                <p class="font-medium text-gray-900">Grade Reports</p>
                <p class="text-sm text-gray-500">Automatically send monthly grade summaries.</p>
              </div>
              <input type="checkbox" class="h-4 w-4 text-blue-600 focus:ring-blue-500 border-gray-300 rounded">
            </div>
          </div>
        </div>
      </div>

      <!-- Side Column -->
      <div class="space-y-6">
        <div class="bg-white rounded-lg shadow-md p-6">
          <h3 class="text-lg font-bold text-gray-900 mb-4">Subscription</h3>
          <div class="text-center py-4">
            <div class="bg-blue-100 text-blue-800 text-xs font-bold px-3 py-1 rounded-full inline-block mb-2">Premium Plan</div>
            <p class="text-3xl font-bold text-gray-900">$49<span class="text-sm text-gray-500 font-normal">/mo</span></p>
            <p class="text-sm text-gray-500 mt-1">Next billing date: June 1, 2026</p>
          </div>
          <button class="w-full border border-gray-300 text-gray-700 py-2 rounded hover:bg-gray-50 transition-colors text-sm font-medium">Manage Billing</button>
        </div>

        <div class="bg-red-50 rounded-lg shadow-md p-6 border border-red-100">
          <h3 class="text-lg font-bold text-red-900 mb-2">Danger Zone</h3>
          <p class="text-sm text-red-700 mb-4">Permanently delete school data and all user accounts.</p>
          <button class="w-full bg-red-600 text-white py-2 rounded hover:bg-red-700 transition-colors text-sm font-medium">Delete School Account</button>
        </div>
      </div>
    </div>
  </div>
</RoleLayout>
