---
import Layout from '../../layouts/Base.astro';
import { getAuthFromCookie } from '../../lib/auth';

// Get user from cookie
const user = getAuthFromCookie(Astro.cookies);

if (!user) {
  return Astro.redirect('/?error=not_authenticated');
}

// Get students data
let students = [];
let error = null;

try {
  const url = new URL(Astro.request.url);
  const searchParams = url.searchParams.toString();
  const apiUrl = `${import.meta.env.PUBLIC_API_URL}/api/students${searchParams ? '?' + searchParams : ''}`;
  
  const response = await fetch(apiUrl, {
    headers: {
      'Cookie': Astro.request.headers.get('cookie') || ''
    }
  });
  
  if (response.ok) {
    const data = await response.json();
    students = data.students || [];
  } else {
    error = 'Failed to fetch students';
  }
} catch (err) {
  console.error('Error fetching students:', err);
  error = 'Error loading students';
}

// Determine layout based on role
let roleLayout;
switch (user.role) {
  case 'admin':
    roleLayout = '../../layouts/Admin.astro';
    break;
  case 'teacher':
    roleLayout = '../../layouts/Teacher.astro';
    break;
  case 'parent':
    roleLayout = '../../layouts/Parent.astro';
    break;
  default:
    roleLayout = '../../layouts/Base.astro';
}

const LayoutComponent = await import(roleLayout);
const RoleLayout = LayoutComponent.default;
---

<RoleLayout title="Students - School Management System">
  <div class="space-y-6">
    <!-- Header -->
    <div class="bg-white rounded-lg shadow-md p-6">
      <div class="flex justify-between items-center">
        <div>
          <h1 class="text-2xl font-bold text-gray-900">Students</h1>
          <p class="text-gray-600 mt-1">
            Manage and view student information
          </p>
        </div>
        {(user.role === 'admin' || user.role === 'teacher') && (
          <button 
            class="px-4 py-2 bg-blue-600 text-white hover:bg-blue-700 rounded-md transition-colors"
            hx-get="/students/create"
            hx-target="#modal-content"
            hx-trigger="click"
          >
            Add Student
          </button>
        )}
      </div>
    </div>

    <!-- Filters and Search -->
    <div class="bg-white rounded-lg shadow-md p-6">
      <form 
        class="grid grid-cols-1 md:grid-cols-3 gap-4"
        hx-get="/students"
        hx-target="#students-container"
        hx-trigger="keyup delay:500ms, change"
        hx-include="input, select"
      >
        <div>
          <label for="search" class="block text-sm font-medium text-gray-700 mb-2">
            Search Students
          </label>
          <input 
            type="text" 
            id="search" 
            name="search"
            placeholder="Search by name or email..."
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
          />
        </div>
        
        <div>
          <label for="grade" class="block text-sm font-medium text-gray-700 mb-2">
            Filter by Grade
          </label>
          <select 
            id="grade" 
            name="grade"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
          >
            <option value="">All Grades</option>
            <option value="1">Grade 1</option>
            <option value="2">Grade 2</option>
            <option value="3">Grade 3</option>
            <option value="4">Grade 4</option>
            <option value="5">Grade 5</option>
            <option value="6">Grade 6</option>
            <option value="7">Grade 7</option>
            <option value="8">Grade 8</option>
            <option value="9">Grade 9</option>
            <option value="10">Grade 10</option>
            <option value="11">Grade 11</option>
            <option value="12">Grade 12</option>
          </select>
        </div>
        
        <div class="flex items-end">
          <button 
            type="button"
            class="w-full px-4 py-2 text-gray-700 bg-gray-100 hover:bg-gray-200 rounded-md transition-colors"
            onclick="resetFilters()"
          >
            Reset Filters
          </button>
        </div>
      </form>
    </div>

    <!-- Students List -->
    <div id="students-container">
      {error ? (
        <div class="bg-red-50 border border-red-200 rounded-md p-4">
          <div class="flex">
            <div class="flex-shrink-0">
              <svg class="h-5 w-5 text-red-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
              </svg>
            </div>
            <div class="ml-3">
              <h3 class="text-sm font-medium text-red-800">Error</h3>
              <p class="mt-1 text-sm text-red-700">{error}</p>
            </div>
          </div>
        </div>
      ) : (
        <div class="bg-white rounded-lg shadow-md overflow-hidden">
          <div class="px-6 py-4 border-b border-gray-200">
            <h3 class="text-lg font-semibold text-gray-900">
              All Students ({students.length})
            </h3>
          </div>

          <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-gray-200">
              <thead class="bg-gray-50">
                <tr>
                  <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                    Name
                  </th>
                  <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                    Grade
                  </th>
                  <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                    Email
                  </th>
                  <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                    Enrolled
                  </th>
                  {(user.role === 'admin' || user.role === 'teacher') && (
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                      Actions
                    </th>
                  )}
                </tr>
              </thead>
              <tbody class="bg-white divide-y divide-gray-200">
                {students.length === 0 ? (
                  <tr>
                    <td colSpan={(user.role === 'admin' || user.role === 'teacher') ? "5" : "4"} class="px-6 py-12 text-center text-gray-500">
                      <div class="flex flex-col items-center">
                        <svg class="w-12 h-12 text-gray-400 mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" />
                        </svg>
                        <p class="text-lg font-medium">No students found</p>
                        <p class="text-sm">Try adjusting your search or filters</p>
                        {(user.role === 'admin' || user.role === 'teacher') && (
                          <button 
                            class="mt-4 px-4 py-2 bg-blue-600 text-white hover:bg-blue-700 rounded-md transition-colors text-sm"
                            hx-get="/students/create"
                            hx-target="#modal-content"
                            hx-trigger="click"
                          >
                            Add First Student
                          </button>
                        )}
                      </div>
                    </td>
                  </tr>
                ) : (
                  students.map((student) => (
                    <tr class="hover:bg-gray-50">
                      <td class="px-6 py-4 whitespace-nowrap">
                        <div class="flex items-center">
                          <div class="h-10 w-10 rounded-full bg-blue-100 flex items-center justify-center mr-3">
                            <span class="text-blue-600 font-semibold">
                              {student.first_name.charAt(0)}{student.last_name.charAt(0)}
                            </span>
                          </div>
                          <div>
                            <div class="text-sm font-medium text-gray-900">
                              {student.first_name} {student.last_name}
                            </div>
                            <div class="text-sm text-gray-500">
                              ID: {student.id}
                            </div>
                          </div>
                        </div>
                      </td>
                      <td class="px-6 py-4 whitespace-nowrap">
                        <span class="px-2 py-1 inline-flex text-xs leading-5 font-semibold rounded-full bg-blue-100 text-blue-800">
                          Grade {student.grade_level}
                        </span>
                      </td>
                      <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                        {student.email || (
                          <span class="text-gray-400 italic">No email</span>
                        )}
                      </td>
                      <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                        {new Date(student.enrollment_date).toLocaleDateString()}
                      </td>
                      {(user.role === 'admin' || user.role === 'teacher') && (
                        <td class="px-6 py-4 whitespace-nowrap text-sm font-medium">
                          <div class="flex space-x-2">
                            <a 
                              href={`/students/${student.id}`}
                              class="text-blue-600 hover:text-blue-900 transition-colors"
                            >
                              View
                            </a>
                            <button 
                              class="text-indigo-600 hover:text-indigo-900 transition-colors"
                              hx-get={`/students/${student.id}/edit`}
                              hx-target="#modal-content"
                              hx-trigger="click"
                            >
                              Edit
                            </button>
                            <button 
                              class="text-red-600 hover:text-red-900 transition-colors"
                              hx-delete={`/api/students/${student.id}`}
                              hx-target="closest tr"
                              hx-trigger="click"
                              hx-confirm="Are you sure you want to delete this student?"
                            >
                              Delete
                            </button>
                          </div>
                        </td>
                      )}
                    </tr>
                  ))
                )}
              </tbody>
            </table>
          </div>
        </div>
      )}
    </div>
  </div>

  <!-- Modal for create/edit forms -->
  <div id="modal-container" class="hidden fixed inset-0 bg-gray-600 bg-opacity-50 overflow-y-auto h-full w-full z-50">
    <div class="relative top-20 mx-auto p-5 border w-96 shadow-lg rounded-md bg-white">
      <div class="mt-3">
        <div class="flex justify-between items-center mb-4">
          <h3 class="text-lg font-medium text-gray-900">Student Form</h3>
          <button 
            class="text-gray-400 hover:text-gray-600"
            onclick="closeModal()"
          >
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
        </div>
        <div id="modal-content">
          <!-- Content will be loaded here -->
        </div>
      </div>
    </div>
  </div>

  <script>
    function resetFilters() {
      document.getElementById('search').value = '';
      document.getElementById('grade').value = '';
      htmx.trigger('#students-container', 'refresh');
    }

    function closeModal() {
      document.getElementById('modal-container').classList.add('hidden');
    }

    // Close modal when clicking outside
    document.getElementById('modal-container').addEventListener('click', function(e) {
      if (e.target === this) {
        closeModal();
      }
    });
  </script>
</RoleLayout>
