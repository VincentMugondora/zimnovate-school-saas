---
import Layout from '../../layouts/Base.astro';
import { getAuthFromCookie } from '../../lib/auth';

// Get user from cookie
const user = getAuthFromCookie(Astro.cookies);

if (!user) {
  return Astro.redirect('/?error=not_authenticated');
}

// Get URL parameters
const url = new URL(Astro.request.url);
const classId = url.searchParams.get('classId') || '';
const studentId = url.searchParams.get('studentId') || '';
const gradingPeriod = url.searchParams.get('gradingPeriod') || 'Term 1';

// Get grades and classes data
let gradesData = [];
let classes = [];
let students = [];
let error = null;

try {
  // Get classes
  const classesUrl = user.role === 'teacher' 
    ? `${Astro.url.origin}/api/classes?teacherId=${user.id}`
    : `${Astro.url.origin}/api/classes`;
  
  const classesResponse = await fetch(classesUrl, {
    headers: {
      'Cookie': Astro.request.headers.get('cookie') || ''
    }
  });
  
  if (classesResponse.ok) {
    const classesData = await classesResponse.json();
    classes = classesData.classes || classesData || [];
  }

  // Get grades data
  const gradesUrl = `${Astro.url.origin}/api/grades${studentId ? '?studentId=' + studentId : ''}`;
  const gradesResponse = await fetch(gradesUrl, {
    headers: {
      'Cookie': Astro.request.headers.get('cookie') || ''
    }
  });
  
  if (gradesResponse.ok) {
    const gradesResult = await gradesResponse.json();
    gradesData = gradesResult || [];
  }

  // Get students if class is selected
  if (classId) {
    const studentsUrl = `${Astro.url.origin}/api/students`;
    const studentsResponse = await fetch(studentsUrl, {
      headers: {
        'Cookie': Astro.request.headers.get('cookie') || ''
      }
    });
    
    if (studentsResponse.ok) {
      const studentsResult = await studentsResponse.json();
      students = studentsResult.students || [];
    }
  }

} catch (err) {
  console.error('Error fetching grades data:', err);
  error = 'Error loading grades data';
}

import AdminLayout from '../../layouts/Admin.astro';
import TeacherLayout from '../../layouts/Teacher.astro';
import ParentLayout from '../../layouts/Parent.astro';

const layouts = {
  admin: AdminLayout,
  teacher: TeacherLayout,
  parent: ParentLayout,
  default: Layout
};

const RoleLayout = layouts[user.role as keyof typeof layouts] || layouts.default;
---

<RoleLayout title="Grades - School Management System">
  <div class="space-y-6">
    <!-- Header -->
    <div class="bg-white rounded-lg shadow-md p-6">
      <div class="flex justify-between items-center">
        <div>
          <h1 class="text-2xl font-bold text-gray-900">Grades</h1>
          <p class="text-gray-600 mt-1">
            Manage and view student grades
          </p>
        </div>
        <div class="flex items-center space-x-2">
          <div id="grade-sync-status" class="w-2 h-2 bg-green-500 rounded-full" title="All changes saved"></div>
          <span class="text-sm text-gray-500">Auto-save enabled</span>
        </div>
      </div>
    </div>

    <!-- Filters and Selection -->
    <div class="bg-white rounded-lg shadow-md p-6">
      <form class="grid grid-cols-1 md:grid-cols-4 gap-4">
        <div>
          <label for="classId" class="block text-sm font-medium text-gray-700 mb-2">
            Class
          </label>
          <select 
            id="classId" 
            name="classId"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
            hx-get="/grades"
            hx-target="#grades-content"
            hx-include="select[name='gradingPeriod'], select[name='studentId']"
            hx-trigger="change"
          >
            <option value="">All Classes</option>
            {classes.map((classItem) => (
              <option value={classItem.id} selected={classItem.id === classId}>
                {classItem.name} - {classItem.subject} (Grade {classItem.grade_level})
              </option>
            ))}
          </select>
        </div>
        
        <div>
          <label for="gradingPeriod" class="block text-sm font-medium text-gray-700 mb-2">
            Grading Period
          </label>
          <select 
            id="gradingPeriod" 
            name="gradingPeriod"
            class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
            hx-get="/grades"
            hx-target="#grades-content"
            hx-include="select[name='classId'], select[name='studentId']"
            hx-trigger="change"
          >
            <option value="Term 1" selected={gradingPeriod === 'Term 1'}>Term 1</option>
            <option value="Term 2" selected={gradingPeriod === 'Term 2'}>Term 2</option>
            <option value="Term 3" selected={gradingPeriod === 'Term 3'}>Term 3</option>
            <option value="Final" selected={gradingPeriod === 'Final'}>Final Exam</option>
          </select>
        </div>

        {user.role === 'parent' && (
          <div>
            <label for="studentId" class="block text-sm font-medium text-gray-700 mb-2">
              Student
            </label>
            <select 
              id="studentId" 
              name="studentId"
              class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
              hx-get="/grades"
              hx-target="#grades-content"
              hx-include="select[name='classId'], select[name='gradingPeriod']"
              hx-trigger="change"
            >
              <option value="">All Children</option>
              {/* Students would be populated based on parent's children */}
            </select>
          </div>
        )}
        
        <div class="flex items-end">
          <button 
            type="button"
            class="w-full px-4 py-2 bg-green-600 text-white hover:bg-green-700 rounded-md transition-colors"
            onclick="exportGrades()"
          >
            Export Report
          </button>
        </div>
      </form>
    </div>

    <!-- Grades Content -->
    <div id="grades-content">
      {error ? (
        <div class="bg-red-50 border border-red-200 rounded-md p-4">
          <div class="flex">
            <div class="flex-shrink-0">
              <svg class="h-5 w-5 text-red-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
              </svg>
            </div>
            <div class="ml-3">
              <h3 class="text-sm font-medium text-red-800">Error</h3>
              <p class="mt-1 text-sm text-red-700">{error}</p>
            </div>
          </div>
        </div>
      ) : classId && (user.role === 'admin' || user.role === 'teacher') ? (
        <!-- Grade entry form for teachers/admins -->
        <div class="bg-white rounded-lg shadow-md p-6">
          <div class="flex justify-between items-center mb-6">
            <div>
              <h3 class="text-lg font-semibold text-gray-900">
                Enter Grades - {classes.find(c => c.id === classId)?.name || 'Class'}
              </h3>
              <p class="text-sm text-gray-500">
                {gradingPeriod} • {students.length} students
              </p>
            </div>
            <div id="grade-save-status" class="text-sm text-gray-500">
              Ready to save changes
            </div>
          </div>

          {students.length > 0 ? (
            <div class="overflow-x-auto">
              <table class="min-w-full divide-y divide-gray-200">
                <thead class="bg-gray-50">
                  <tr>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                      Student
                    </th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                      Assessment
                    </th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                      Grade (0-100)
                    </th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                      Status
                    </th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                      Notes
                    </th>
                  </tr>
                </thead>
                <tbody class="bg-white divide-y divide-gray-200">
                  {students.map((student) => {
                    const existingGrade = gradesData.find(g => g.student_id === student.id && g.grading_period === gradingPeriod);
                    return (
                      <tr class="hover:bg-gray-50">
                        <td class="px-6 py-4 whitespace-nowrap">
                          <div class="flex items-center">
                            <div class="h-8 w-8 rounded-full bg-blue-100 flex items-center justify-center mr-3">
                              <span class="text-blue-600 font-semibold text-sm">
                                {student.first_name.charAt(0)}{student.last_name.charAt(0)}
                              </span>
                            </div>
                            <div>
                              <div class="text-sm font-medium text-gray-900">
                                {student.first_name} {student.last_name}
                              </div>
                              <div class="text-sm text-gray-500">
                                Grade {student.grade_level}
                              </div>
                            </div>
                          </div>
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap">
                          <input 
                            type="text" 
                            name={`assessment_${student.id}`}
                            placeholder="e.g., Midterm Exam"
                            value="Assignment"
                            class="w-32 px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 text-sm"
                          />
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap">
                          <input 
                            type="number" 
                            name={`grade_${student.id}`}
                            min="0" 
                            max="100"
                            value={existingGrade?.grade || ''}
                            placeholder="0-100"
                            class="w-20 px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                            onchange="saveGrade('{student.id}', this.value, '{classId}', '{gradingPeriod}')"
                          />
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap">
                          <span 
                            id={`status_${student.id}`}
                            class="px-2 py-1 inline-flex text-xs leading-5 font-semibold rounded-full"
                          >
                            {existingGrade ? (
                              existingGrade.grade >= 70 ? (
                                <span class="bg-green-100 text-green-800">Passing</span>
                              ) : (
                                <span class="bg-red-100 text-red-800">Needs Improvement</span>
                              )
                            ) : (
                              <span class="bg-gray-100 text-gray-800">Not Graded</span>
                            )}
                          </span>
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                          <input 
                            type="text" 
                            name={`notes_${student.id}`}
                            placeholder="Optional notes..."
                            class="w-32 px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 text-sm"
                          />
                        </td>
                      </tr>
                    );
                  })}
                </tbody>
              </table>
            </div>
          ) : (
            <div class="text-center py-8 text-gray-500">
              <svg class="w-12 h-12 text-gray-400 mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
              </svg>
              <p class="text-lg font-medium">No students found</p>
              <p class="text-sm">This class has no enrolled students</p>
            </div>
          )}
        </div>
      ) : (
        <!-- Grades view for parents and general viewing -->
        <div class="bg-white rounded-lg shadow-md p-6">
          <h3 class="text-lg font-semibold text-gray-900 mb-4">
            Grade Report - {gradingPeriod}
          </h3>
          
          {gradesData.length > 0 ? (
            <div class="space-y-4">
              {gradesData.map((grade) => (
                <div class="border border-gray-200 rounded-lg p-4">
                  <div class="flex justify-between items-center">
                    <div>
                      <h4 class="font-medium text-gray-900">
                        {grade.students?.first_name} {grade.students?.last_name}
                      </h4>
                      <p class="text-sm text-gray-500">
                        {grade.classes?.name} - {grade.classes?.subject}
                      </p>
                      <p class="text-sm text-gray-500">
                        Grade {grade.students?.grade_level}
                      </p>
                    </div>
                    <div class="text-right">
                      <div class="text-2xl font-bold text-gray-900">
                        {grade.grade}%
                      </div>
                      <span class={`px-2 py-1 inline-flex text-xs leading-5 font-semibold rounded-full ${
                        grade.grade >= 70 ? 'bg-green-100 text-green-800' :
                        grade.grade >= 50 ? 'bg-yellow-100 text-yellow-800' :
                        'bg-red-100 text-red-800'
                      }`}>
                        {grade.grade >= 70 ? 'Excellent' :
                         grade.grade >= 50 ? 'Good' : 'Needs Improvement'}
                      </span>
                    </div>
                  </div>
                </div>
              ))}
            </div>
          ) : (
            <div class="text-center py-8 text-gray-500">
              <svg class="w-12 h-12 text-gray-400 mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
              </svg>
              <p class="text-lg font-medium">No grades found</p>
              <p class="text-sm">No grades have been recorded for this period</p>
            </div>
          )}
        </div>
      )}
    </div>

    <!-- Grade Statistics -->
    {gradesData.length > 0 && (
      <div class="bg-white rounded-lg shadow-md p-6">
        <h3 class="text-lg font-semibold text-gray-900 mb-4">Grade Statistics</h3>
        <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
          <div class="text-center">
            <div class="text-2xl font-bold text-blue-600">
              {(gradesData.reduce((sum, g) => sum + g.grade, 0) / gradesData.length).toFixed(1)}%
            </div>
            <p class="text-sm text-gray-500">Class Average</p>
          </div>
          <div class="text-center">
            <div class="text-2xl font-bold text-green-600">
              {gradesData.filter(g => g.grade >= 70).length}
            </div>
            <p class="text-sm text-gray-500">Passing (≥70%)</p>
          </div>
          <div class="text-center">
            <div class="text-2xl font-bold text-yellow-600">
              {gradesData.filter(g => g.grade >= 50 && g.grade < 70).length}
            </div>
            <p class="text-sm text-gray-500">Average (50-69%)</p>
          </div>
          <div class="text-center">
            <div class="text-2xl font-bold text-red-600">
              {gradesData.filter(g => g.grade < 50).length}
            </div>
            <p class="text-sm text-gray-500">Below Average (<50%)</p>
          </div>
        </div>
      </div>
    )}
  </div>

  <script>
    function saveGrade(studentId, grade, classId, gradingPeriod) {
      if (grade === '') return;
      
      const statusEl = document.getElementById('grade-save-status');
      statusEl.textContent = 'Saving...';
      statusEl.className = 'text-sm text-blue-600';
      
      fetch('/api/grades', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify({
          student_id: studentId,
          class_id: classId,
          grade: parseFloat(grade),
          grading_period: gradingPeriod
        })
      })
      .then(response => response.json())
      .then(data => {
        if (data.error) {
          statusEl.textContent = 'Error: ' + data.error;
          statusEl.className = 'text-sm text-red-600';
        } else {
          statusEl.textContent = 'Saved: ' + new Date().toLocaleTimeString();
          statusEl.className = 'text-sm text-green-600';
          
          // Update status badge
          const statusBadge = document.getElementById(`status_${studentId}`);
          if (statusBadge) {
            if (grade >= 70) {
              statusBadge.innerHTML = '<span class="bg-green-100 text-green-800">Passing</span>';
            } else {
              statusBadge.innerHTML = '<span class="bg-red-100 text-red-800">Needs Improvement</span>';
            }
          }
          
          // Update sync status
          const syncIndicator = document.getElementById('grade-sync-status');
          syncIndicator.className = 'w-2 h-2 bg-green-500 rounded-full';
          
          setTimeout(() => {
            statusEl.textContent = 'All changes saved';
            statusEl.className = 'text-sm text-gray-500';
          }, 3000);
        }
      })
      .catch(error => {
        console.error('Error:', error);
        statusEl.textContent = 'Error saving grade';
        statusEl.className = 'text-sm text-red-600';
      });
    }

    function exportGrades() {
      window.print();
    }
  </script>
</RoleLayout>
